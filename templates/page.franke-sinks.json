    "image_with_text_WdwnRE": {
      "type": "image-with-text",
      "blocks": {
        "heading_EQkiRy": {
          "type": "heading",
          "settings": {
            "heading": "Smart Accessories",
            "heading_size": "h1"
          }
        },
        "text_pztkYY": {
          "type": "text",
          "settings": {
            "text": "<p>Maximise your sink’s potential with a range of compatible accessories. Whether it’s a custom-fit chopping board, stainless steel colander, drainer basket, or waste disposer, Franke accessories turn your sink into a multi-functional workstation. Explore our <a href=\"/collections/kitchen\" title=\"Kitchen Renovation\">kitchen collection</a>  to find everything you need for a streamlined, efficient cooking experience.</p>",
            "text_style": "body"
          }
        }
