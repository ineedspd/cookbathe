    "image_with_text_W7NjtP": {
      "type": "image-with-text",
      "blocks": {
        "heading_zNKXan": {
          "type": "heading",
          "settings": {
            "heading": "Unmatched Functionality & Everyday Convenience",
            "heading_size": "h2"
          }
        },
        "text_E7ntte": {
          "type": "text",
          "settings": {
            "text": "<p>Franke sinks are built with usability in mind. Their clever designs often include integrated drainage boards, sound-absorbing materials, and ergonomic bowl shapes to simplify meal prep and clean-up. These thoughtful features ensure your sink isn’t just good-looking, but also a pleasure to use every day.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "heading_zNKXan",
        "text_E7ntte"
      ],
