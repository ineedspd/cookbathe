    "image_with_text_YjabJR": {
      "type": "image-with-text",
      "blocks": {
        "heading_B3LFRC": {
          "type": "heading",
          "settings": {
            "heading": "Experience the Difference of Franke Sinks",
            "heading_size": "h2"
          }
        },
        "text_gaqARC": {
          "type": "text",
          "settings": {
            "text": "<p>Transform your kitchen into a culinary haven with Franke’s exceptional range of sinks, designed specifically for the demands of modern Australian homes. Known for their premium craftsmanship, innovative features, and timeless appeal, Franke sinks are a perfect blend of style and durability. Whether you’re renovating an existing kitchen or building a new one, our selection of <a href=\"/collections/franke-sinks\" title=\"Franke Sinks\">Franke Sinks</a> at Cook & Bathe ensures you’ll find the ideal solution to meet your needs.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "heading_B3LFRC",
        "text_gaqARC"
      ],
      "settings": {
        "image": "shopify://shop_images/AM002_Kubus_Berlin.jpg",
        "height": "small",
        "desktop_image_width": "medium",
