    "image_with_text_WPhbhr": {
      "type": "image-with-text",
      "blocks": {
        "heading_mQTbGi": {
          "type": "heading",
          "settings": {
            "heading": "Colours & Finishes",
            "heading_size": "h2"
          }
        },
        "text_KAkQYm": {
          "type": "text",
          "settings": {
            "text": "<p>From the polished shine of stainless steel to the subtle elegance of anthracite granite, Franke sinks come in a variety of finishes and tones. This diverse palette ensures your sink will complement your kitchen’s aesthetic, whether your style is modern, rustic, or minimalist.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "heading_mQTbGi",
        "text_KAkQYm"
      ],
      "settings": {
        "image": "shopify://shop_images/BXM210-40AN_lifestyle_3398ea58-03d0-45d2-9194-329f4126cd6c.jpg",
