      "type": "image-with-text",
      "blocks": {
        "heading_CkpMGU": {
          "type": "heading",
          "settings": {
            "heading": "Styles for Every Layout",
            "heading_size": "h2"
          }
        },
        "text_tbifC9": {
          "type": "text",
          "settings": {
            "text": "<p>Choose from top-mount, undermount, or flush-mount options to achieve the perfect fit for your bench space and workflow. Pair your new sink with matching  <a href=\"/collections/franke-tapware\" title=\"Franke Tapware\">Franke Tapware</a> to create a cohesive, functional kitchen environment.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "heading_CkpMGU",
        "text_tbifC9"
      ],
      "settings": {
