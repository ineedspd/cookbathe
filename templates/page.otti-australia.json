        },
        "text_4cz6dH": {
          "type": "text",
          "settings": {
            "text": ""
          }
        },
        "text_zJgiE8": {
          "type": "text",
          "settings": {
            "text": "<h3>What types of bathroom fixtures does Otti Australia offer?</h3>"
          }
        },
        "text_Ky7QXr": {
          "type": "text",
          "settings": {
            "text": "<p>Otti Australia provides a wide range of premium bathroom fixtures, including basins, baths, mirrors, and vanities. Each product is crafted with a focus on quality, design, and functionality to enhance any bathroom space.</p>"
          }
        }
      },
      "block_order": [
        "heading_wxxdmC",
        "text_4cz6dH",
        "text_zJgiE8",
        "text_Ky7QXr"
      ],
