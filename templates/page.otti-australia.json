      "blocks": {
        "heading_nLJczm": {
          "type": "heading",
          "settings": {
            "heading": "Otti LED Mirrors – Style Meets Function with Built-In Illumination",
            "heading_size": "h2"
          }
        },
        "text_yXmqmR": {
          "type": "text",
          "settings": {
            "text": "<p>Complete your bathroom design with Otti Australia's stunning mirrors. Our mirrors are designed to add both functionality and style to your space.</p><p><strong>LED Lighting:</strong> Integrated LED lights for optimal illumination. Otti mirrors are designed to add both functionality and style to your space. Explore our range of LED shaving cabinets, including the <a href=\"URL\">Otti LED Archie Shaving Cabinet Matte White</a>, for sleek and functional bathroom lighting solutions.”</p><p><strong>Anti-Fog Features:</strong> Ensures a clear reflection even in steamy conditions.</p><p><strong>Various Shapes and Sizes:</strong> Available in multiple configurations to fit your space.</p><p>Discover our collection of Otti mirrors to enhance your bathroom's functionality and aesthetics.</p>",
            "text_style": "body"
          }
        },
        "button_fxV7PM": {
          "type": "button",
