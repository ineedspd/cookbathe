    "rich_text_6VLmMn": {
      "type": "rich-text",
      "blocks": {
        "text_qVTHj9": {
          "type": "text",
          "settings": {
            "text": "<h3>What warranties are provided with Otti bathroom fixtures?</h3>"
          }
        },
        "text_tJ7RKx": {
          "type": "text",
          "settings": {
            "text": "<p>Otti Australia stands by the quality of its products and provides warranties to cover any manufacturing defects. The length and specifics of the warranty vary by product type, generally covering structural integrity and finish. It’s best to consult the warranty information provided with each item or speak to customer support for detailed warranty coverage for a particular product.</p>"
          }
        }
      },
      "block_order": [
        "text_qVTHj9",
        "text_tJ7RKx"
      ],
      "settings": {
        "desktop_content_position": "center",
        "content_alignment": "left",
        "color_scheme": "background-1",
        "full_width": true,
        "padding_top": 0,
