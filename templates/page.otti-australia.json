      }
    },
    "rich_text_9dUtqP": {
      "type": "rich-text",
      "blocks": {
        "text_fXNPR7": {
          "type": "text",
          "settings": {
            "text": "<h3>Where can I view Otti products in person before making a purchase?</h3>"
          }
        },
        "text_8E4zmC": {
          "type": "text",
          "settings": {
            "text": "<p>Otti products are available to view at select showrooms across Australia, allowing customers to experience the quality and design firsthand. You can visit the Cook & Bathe website to find a <a href=\"https://www.cookandbathe.com.au/pages/store-locations\" title=\"Showroom locations\">showroom location</a> near you or contact customer support to arrange a visit. This way, you can see the finishes, size, and design details up close before making a purchase decision.</p>"
          }
        }
      },
      "block_order": [
        "text_fXNPR7",
        "text_8E4zmC"
      ],
      "settings": {
        "desktop_content_position": "center",
        "content_alignment": "left",
        "color_scheme": "background-1",
