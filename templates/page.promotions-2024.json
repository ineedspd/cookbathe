          }
        },
        "column_AerfmN": {
          "type": "column",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/76NimmoSt_Bathroom3.jpg",
            "title": "Tapware under $200",
            "text": "<p>Explore our <strong>Tapware Under $200 </strong>– a stylish, budget-friendly range designed to elevate your kitchen or bathroom. Perfect for renovations, upgrades, or investment properties. Style meets value - no compromise necessary.</p>",
            "link_label": "Shop Tapware",
            "link": "https://www.cookandbathe.com.au/collections/tapware-under-200"
          }
        },
        "column_RhRCtg": {
          "type": "column",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/basins_promotion_page_timberline.jpg",
            "title": "Basins Under $300",
            "text": "<p>Shop our range of stylish and affordable <strong>bathroom basins</strong> under <strong>$300</strong>. Perfect for modern renovations, these quality basins combine sleek design with everyday functionality - without exceeding your budget.</p>",
            "link_label": "Shop Basins",
            "link": "https://www.cookandbathe.com.au/collections/basins-under-300"
          }
        },
        "column_HkEEFw": {
          "type": "column",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/sinks_accessories_promotion_page_seima.jpg",
            "title": "Sinks & Accessories Under $400",
            "text": "<p>Discover affordable <strong>kitchen sinks and accessories</strong> under <strong>$400</strong>. Stylish, practical, and perfect for adding quality to any Australian kitchen on a budget.</p>",
            "link_label": "Shop Sinks & Accessories",
            "link": "https://www.cookandbathe.com.au/collections/sinks-and-accessories-under-400"
          }
        },
        "column_737jzb": {
          "type": "column",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/appliances_promotion_page_westinghouse.jpg",
            "title": "Kitchen Appliances Under $600",
            "text": "<p>Explore our selection of <strong>kitchen appliances </strong>under<strong> $600</strong>, combining reliable performance with modern style. From compact ovens to efficient rangehoods, these affordable options are perfect for everyday Australian kitchens.</p>",
            "link_label": "Shop Kitchen Appliances",
            "link": "https://www.cookandbathe.com.au/collections/appliances-under-500"
          }
        },
        "column_tmJjKq": {
          "type": "column",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/smart-toilets.jpg",
            "title": "Toilets Under $600",
            "text": "<p>Explore our range of stylish and durable <strong>toilets </strong>under<strong> $600</strong> that combine quality, water efficiency, and modern design. Perfect for budget-friendly renovations or upgrades, these toilets offer great value without compromising performance or style.</p>",
            "link_label": "Shop Toilets",
            "link": "shopify://collections/toilets-under-600"
          }
        },
        "column_paybdq": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Sizzling-sink-promo_mobileV2_61150778-bdd2-4c7a-81f6-1afc8eb7397f.jpg",
            "title": "Sink Clearance Sale",
            "text": "<p>Shop our exclusive <strong>sink clearance sale</strong> and save on high-quality kitchen sinks. Featuring modern designs, durable materials, and timeless styles, these discounted sinks are ideal for kitchen renovations or upgrades. Hurry - stock is limited, and once they’re gone, they’re gone!</p>",
            "link_label": "Shop the Range",
            "link": "https://www.cookandbathe.com.au/collections/sizzling-sink-sale"
          }
        },
        "column_CyrVWB": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/MRG120-35_35-B_PW_10IrmaGr_5.jpg",
            "title": "Franke Kitchen Sinks & Tapware - Save Over 30%",
            "text": "<p>Discover premium <strong>Franke sinks and kitchen tapware</strong> at unbeatable prices – now with over <strong>30% off selected products</strong>. Known for Swiss craftsmanship and over 100 years of innovation, <strong>Franke kitchen solutions</strong> deliver the perfect balance of design, durability, and everyday functionality. From modern <strong>Franke stainless steel sinks</strong> to stylish <strong>kitchen mixers</strong>, elevate your home with timeless quality at a fraction of the price.</p>",
            "link_label": "Shop Franke",
            "link": "https://www.cookandbathe.com.au/collections/franke"
          }
        },
        "column_eWecMc": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/640-5000-12_VS6000-12_Lifestyle_1.jpg",
            "title": "Phoenix Bathroom & Kitchen Tapware - Save Over 20%",
            "text": "<p>Upgrade your home with <strong>Phoenix Tapware</strong>, now available with savings of <strong>over 20%</strong> across selected ranges. Renowned for design excellence and superior craftsmanship, Phoenix offers a wide selection of <strong>bathroom taps, kitchen mixers, and shower sets</strong> to suit every style. Whether you’re renovating or simply refreshing your space, our curated <strong>Phoenix tapware collection</strong> blends innovation with elegance to transform your kitchen and bathroom.</p>",
            "link_label": "Shop Phoenix Tapware",
            "link": "https://www.cookandbathe.com.au/collections/phoenix"
          }
        },
        "column_wQ7awA": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/CRZ25511_lifestyle9.jpg",
            "title": "Kleenmaid Appliances - Save Over 30%",
            "text": "<p>Upgrade your home with premium <strong>Kleenmaid appliances</strong>, now with savings of up to <strong>30% off selected products</strong>. Explore our extensive range, including <strong>Kleenmaid fridges, ovens, cooktops, rangehoods, microwaves, washing machines, and dishwashers</strong> – all designed with innovation, performance, and style in mind. At Cook & Bathe, we bring you authentic Kleenmaid quality to transform your <strong>kitchen and laundry</strong> with appliances built to last.</p>",
            "link_label": "Shop Kleenmaid",
            "link": "https://www.cookandbathe.com.au/collections/kleenmaid"
          }
        },
        "column_JAWcTL": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/OT5036MW_ReynoldsRdBelmont_1_31bba424-94cc-4e54-9781-f7b9449df523.jpg",
            "title": "Otti Bathroom Vanities & Basins - Save Up to 28%",
            "text": "<p>Discover the elegance of <strong>Otti Australia bathroom products</strong>, now available with up to <strong>25% off selected designs</strong>. For over 30 years, Otti has been a leader in <strong>bathroom vanities, basins, and mirrors</strong>, combining refined Australian design with everyday functionality. Perfect for modern renovations or bathroom upgrades, Otti’s range balances <strong>style, quality, and affordability</strong> – making it easier to create a space you’ll love.</p>",
            "link_label": "Shop Otti",
            "link": "https://www.cookandbathe.com.au/collections/otti"
          }
        },
        "column_aGrckd": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/bathroom-05-scene-01.jpg",
            "title": "Domus Living: Luxury Bathware - Save Up to 10%",
            "text": "<p>Elevate your bathroom with <strong>Domus Living bathware</strong>, now available with savings of up to <strong>10% off selected products</strong>. Proudly Australian-owned, Domus Living is renowned for <strong>Italian-made shower bases, solid surface bathtubs, and basins</strong> that combine artisan craftsmanship with modern innovation. Each piece reflects timeless style and premium quality, offering both functionality and elegance. From <strong>custom bathroom solutions</strong> to statement designs, Domus Living brings sophistication to every renovation or upgrade.</p>",
            "link_label": "Shop Domus Living",
            "link": "https://www.cookandbathe.com.au/collections/domus-living"
          }
        },
        "column_7d7AEb": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/24101000_Lifestyle2.jpg",
            "title": "Hansgrohe: Premium Tapware & Showers - Save Up to 20%",
            "text": "<p>Experience the excellence of <strong>Hansgrohe tapware and showers</strong>, now available with savings of up to <strong>20% off selected products</strong>. Renowned worldwide for precision German engineering, Hansgrohe combines innovative design with superior functionality to elevate your bathroom and kitchen. From stylish <strong>Hansgrohe basin mixers</strong> to luxurious <strong>Hansgrohe overhead showers</strong>, every product is crafted to deliver lasting quality and comfort. Explore our curated collection and bring modern elegance into your home at a discounted price.</p>",
            "link_label": "Shop Hansgrohe",
            "link": "shopify://collections/hansgrohe"
          }
        }
