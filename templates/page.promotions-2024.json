        "column_dWQxFq": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/FreeShipping_Tapware.jpg",
            "title": "Tapware – Free Shipping Over $299",
            "text": "<p>Upgrade your kitchen or bathroom with our premium tapware and enjoy free delivery when you spend<strong> $299 or more on selected tapware products</strong>. Explore stylish mixers, pull-out sprays, and gooseneck designs to complete your renovation or refresh. Free shipping applies to eligible tapware products only;<strong> delivery fees for any other items in the same order will be calculated separately at checkout.</strong></p>",
