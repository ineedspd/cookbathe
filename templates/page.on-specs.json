        "testimonial_block_9EGzAX": {
          "type": "testimonial_block",
          "settings": {
            "rating": "shopify://shop_images/Mimosa_Rating.svg",
            "content": "<p>\"The professionalism and deep product knowledge of the Cook & Bathe team make them an invaluable extension of our own. Their responsiveness and dedication to meeting tight build schedules have consistently exceeded our expectations.\"</p>",
            "author": "— Peter Holt, Mimosa Homes"
          }
        },
        "testimonial_block_CHk8T4": {
          "type": "testimonial_block",
          "settings": {
            "rating": "shopify://shop_images/Metronest_Rating.svg",
            "content": "<p>\"Cook & Bathe is great at building relationships with customers. The team are product experts who listen carefully to customer needs and offer tailored solutions, resulting in successful sales. They present information in a way that’s easy to understand, making the whole process smooth and effective.\"</p>",
            "author": "— Megha Gupta Jain, Metronest Homes"
          }
        }
      },
