    "rich_text_ELEVMc": {
      "type": "rich-text",
      "blocks": {
        "heading_EnRWYG": {
          "type": "heading",
          "settings": {
            "heading": "<h3><strong>Hurry, These Offers Won’t Last!</strong></h3>",
            "heading_size": "h2"
          }
        },
        "text_wJyJyt": {
          "type": "text",
          "settings": {
            "text": "<p>Take advantage of these incredible discounts before they’re gone! With up to <strong>60% off kitchen, bathroom, and laundry essentials</strong>, now is the perfect time to invest in quality upgrades that will enhance your home for years to come. Whether you shop online or in-store, <strong>Cook & Bathe</strong> is your destination for premium products at unbeatable prices.</p><p><strong>Shop now</strong> and enjoy our national delivery service, bringing exceptional value and convenience directly to your door. </p>"
          }
        }
      },
