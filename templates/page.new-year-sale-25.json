    "image_with_text_4Cw7QW": {
      "type": "image-with-text",
      "blocks": {
        "heading_8kU7fj": {
          "type": "heading",
          "settings": {
            "heading": "Phoenix Tapware",
            "heading_size": "h1"
          }
        },
        "text_qg49Va": {
          "type": "text",
          "settings": {
            "text": "<p>Renowned for cutting-edge designs and sophisticated finishes, Phoenix Tapware offers everything from <strong>sleek gooseneck taps</strong> to <strong>state-of-the-art basin mixers</strong>. Whether you’re designing a contemporary kitchen or a luxurious bathroom, this collection will exceed your expectations.</p>",
            "text_style": "body"
