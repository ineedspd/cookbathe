    "rich_text_3qAx9n": {
      "type": "rich-text",
      "blocks": {
        "heading_3tWCM3": {
          "type": "heading",
          "settings": {
            "heading": "<h2><strong>Ovens & Cooktops</strong></h2>",
            "heading_size": "h1"
          }
        },
        "text_Tq7myG": {
          "type": "text",
          "settings": {
            "text": "<p>Cooking appliances are the heart of any kitchen. Whether you’re a daily home cook or an occasional entertainer, your choice of oven and cooktop determines not just what you can prepare, but how efficiently and precisely you can do it. At Cook & Bathe, we offer a premium selection of ovens and cooktops that prioritise performance, style, and integration—so you can craft meals with confidence.</p><p>Explore our complete <a href=\"https://www.cookandbathe.com.au/collections/ovens\">Ovens</a> and <a href=\"https://www.cookandbathe.com.au/collections/cooktops\">Cooktops</a> collections to find the ideal match for your kitchen layout, culinary habits, and personal preferences.</p>"
          }
        }
      },
