    "collapsible_content_PJG9x7": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_ma8wfz": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What types of bathroom products can I find at Cook & Bathe?",
            "icon": "none",
            "row_content": "<p>At Cook & Bathe, we offer a comprehensive selection of premium bathroom products including <strong>vanity units</strong>, <strong>freestanding and back-to-wall bathtubs</strong>, <strong>shower systems</strong>, <strong>basins</strong>, <strong>toilets</strong>, <strong>bathroom tapware</strong>, <strong>heated towel rails</strong>, <strong>mirrors</strong>, and <strong>accessories</strong>. Whether you’re updating a powder room or undertaking a full <strong>bathroom renovation</strong>, our curated collection is designed to suit both classic and contemporary spaces.</p>",
            "page": ""
          }
        },
        "collapsible_row_iKBBCK": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Do you provide advice for bathroom renovations?",
            "icon": "none",
            "row_content": "<p>Yes. Our experienced team can help you plan your <strong>bathroom renovation</strong> with expert advice on choosing the right <strong>fixtures, fittings, layout</strong>, and <strong>colour scheme</strong>. Visit one of our showrooms or contact us online for personalised support.</p>",
            "page": ""
          }
        },
        "collapsible_row_EWaYD3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Do you offer water-efficient bathroom tapware and fixtures?",
            "icon": "none",
            "row_content": "<p>Yes. Many of our <strong>bathroom taps</strong>, <strong>toilets</strong>, and <strong>shower heads</strong> are <strong>WELS-rated</strong> to support <strong>water efficiency</strong> without compromising on performance. Look for the WELS label on our product pages to compare eco-friendly options for your bathroom.</p>",
            "page": ""
          }
        },
        "collapsible_row_yKgqwM": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Are your bathroom products suitable for trade customers or builders?",
            "icon": "none",
            "row_content": "<p>Yes. Cook & Bathe supplies <strong>builders, designers, and trade professionals</strong> with high-quality bathroom fixtures and fittings. We offer <strong>competitive trade pricing</strong>, <strong>bulk order solutions</strong>, and expert support with <strong>product selection and availability</strong>. To learn more or register your interest, visit our <a href=\"https://www.cookandbathe.com.au/pages/on-specs\" title=\"https://www.cookandbathe.com.au/pages/on-specs\">Trade Customers page</a>.</p>",
            "page": ""
          }
        }
      },
