    "multicolumn_RN4nb9": {
      "type": "multicolumn",
      "blocks": {
        "column_tKKNd8": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/icon-kitchen.svg",
            "title": "Gas Cooktops",
            "text": "<p><a href=\"https://www.cookandbathe.com.au/collections/gas-cooktops-stove\">Gas Cooktops</a> deliver instant, precise heat, making them a favourite for Australian home cooks who value control and versatility. Perfect for everything from high-heat searing to gentle simmering, gas cooktops cater to diverse cooking styles with features like wok burners and easy-to-use controls. Modern gas cooktops are designed with safety and style in mind, seamlessly blending into any kitchen while providing reliable performance for everyday meals and special occasions.</p>",
            "link_label": "Shop Gas Cooktops",
            "link": "shopify://collections/gas-cooktops-stove"
          }
        },
        "column_zV8BR3": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/icon_electriccooktop.png",
            "title": "Induction Cooktops",
            "text": "<p><a href=\"https://www.cookandbathe.com.au/collections/induction\">Induction Cooktops</a> combine advanced technology with sleek design to bring speed and energy efficiency to your kitchen. Using electromagnetic energy to directly heat your pots and pans, induction cooktops provide rapid heating and precise temperature control while remaining cool to the touch. This makes them a safe, family-friendly option that is easy to clean and perfect for busy households seeking a seamless cooking experience with a modern aesthetic.</p>",
            "link_label": "Shop Induction Cooktops",
            "link": "shopify://collections/induction"
          }
        },
        "column_X346kn": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/icon_electriccooktop.png",
            "title": "Ceramic Cooktops",
            "text": "<p><a href=\"https://www.cookandbathe.com.au/collections/ceramic-cooktops\">Ceramic Cooktops</a> offer a contemporary, minimalist design that complements modern kitchens while providing reliable and consistent heat. With their flat, glass surfaces, ceramic cooktops are easy to clean and maintain, making them a practical choice for homeowners who value simplicity and functionality. Ideal for a wide range of cooking needs, they provide a stylish solution for those looking to upgrade their kitchen with a cooktop that offers both form and function.</p>",
            "link_label": "Shop Ceramic Cooktops",
            "link": "shopify://collections/ceramic-cooktops"
          }
        }
      },
