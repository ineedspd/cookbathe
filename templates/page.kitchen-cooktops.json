    "rich_text_3qAx9n": {
      "type": "rich-text",
      "blocks": {
        "heading_3tWCM3": {
          "type": "heading",
          "settings": {
            "heading": "<h2><strong>Cooktops at Cook & Bathe</strong></h2>",
            "heading_size": "h1"
          }
        },
        "text_Tq7myG": {
          "type": "text",
          "settings": {
            "text": "<p>Cooktops are the heart of your kitchen, influencing not just what you prepare but how efficiently you can cook each meal. At Cook & Bathe, we offer a premium selection of cooktops that blend performance, style, and seamless integration for every kitchen. Whether you love precise control with <a>gas cooktops</a>, the efficiency of <a>induction cooktops</a>, or the sleek design of <a>ceramic cooktops</a>, we have options to match your lifestyle.</p><p>Explore our complete range of cooktops to find the ideal match for your kitchen design, cooking habits, and culinary ambitions.</p>"
          }
        }
      },
      "block_order": [
        "heading_3tWCM3",
        "text_Tq7myG"
      ],
      "name": "t:sections.rich-text.presets.name",
