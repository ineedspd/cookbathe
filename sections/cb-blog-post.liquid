
<div class="blog_post_wrapper position-relative">
  <div class="container">
    {% render 'cb-title-option' %}
    <div class="blog_post_listing">
      <div class="swiper blogs_swiper">
        <div class="swiper-wrapper">
          {% assign id = article.id %}
          {% assign blogs_type = section.blocks | where: 'type', 'blog' %}
          {%- for block in blogs_type -%}
            {% assign blog = blogs[block.settings.blogs] %}
            {% assign limit = 0 %}
            {%- for article in blog.articles %}
              {% if id != article.id and limit < 3 %}
                <div class="swiper-slide">
                  <div class="blog_card position-relative overflow-hidden">
                    <a
                      href="{{ article.url }}"
                      class="d-block blog_card_cover bg_cover"
                    >
                       <img
                    src="{{  article.image | img_url: '280x' }}"
                    srcset="{{  article.image | img_url: '200x' }} 200w,
                            {{  article.image | img_url: '400x' }} 400w,
                            {{  article.image | img_url: '600x' }} 600w,
                            {{  article.image | img_url: '800x' }} 800w,
                            {{  article.image | img_url: 'master' }} 1200w"
                    sizes="(max-width: 600px) 100vw, 600px"
                    alt="{{article.title }}"
                    loading="lazy"
                         height="280"
                         width="420"
style="object-fit:cover;"  class="d-none d-sm-block" />
                         {% comment %}
                      <img
                        src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/blog-post-cover.png"
                        alt="{{ article.title }}"
                        class="d-none d-sm-block"
                      >
                   
                      <img
                        src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/blog-post-mobile-cover.png"
                        alt="{{ article.title }}"
                        class="d-sm-none"
                      >
                         {% endcomment %}
                        <img
                    src="{{  article.image | img_url: '280x' }}"
                    srcset="{{  article.image | img_url: '200x' }} 200w,
                            {{  article.image | img_url: '400x' }} 400w,
                            {{  article.image | img_url: '600x' }} 600w,
                            {{  article.image | img_url: '800x' }} 800w,
                            {{  article.image | img_url: 'master' }} 1200w"
                    sizes="(max-width: 600px) 100vw, 600px"
                    alt="{{article.title }}"
                    loading="lazy"
                         height="177"
                         width="348"
style="object-fit:cover;"  class="d-sm-none" />
                    </a>
                    <div class="blog_card_content">
                      <ul class="list-unstyled meta_data d-flex align-items-center">
                        {% comment %}
                        <li>
                            {%- render 'icon-account' %}
                            {{ article.author -}}
                        </li>
                        {% endcomment %}
                        <li>{%- render 'icon-account' %} Cook & Bathe</li>
                        {% assign count = article.content | size %}
                        <li class="d-none">
                          {% render 'icon-clock' %}
                          {% render 'cb-time-blog', count: count %}
                        </li>
                      </ul>
                      <p>{{ article.title }}</p>
                    </div>
                    <div class="blog_card_cta">
                      <a href="{{ article.url }}" class="btn btn-outline-primary">Read more about {{  article.title }}</a>
                    </div>
                  </div>
                </div>
                {% assign limit = limit | plus: 1 %}
              {% endif %}
            {%- endfor -%}
          {%- endfor -%}
        </div>
        <div class="swiper_control">
          <div class="blogs_swiper_prev swiper-button-prev">&nbsp;</div>
          <div class="blogs_swiper_pagination swiper-pagination"></div>
          <div class="blogs_swiper_next swiper-button-next">&nbsp;</div>
        </div>
      </div>
    </div>
  </div>
</div>
