{% javascript %}
   // var swiper = new Swiper(".blogs_swiper", 
   var data = {
    loop: true,
    slidesPerView: 1,
    spaceBetween: 32,
    pagination: {
      el: ".blogs_swiper_pagination",
      clickable: true,
      type: "fraction",
    },
    navigation: {
      nextEl: ".blogs_swiper_next",
      prevEl: ".blogs_swiper_prev",
    },
    breakpoints: {
      576: {
        slidesPerView: 1,
      },
      768: {
        slidesPerView: 2,
      },
      992: {
        slidesPerView: 3,
        loop: false,
      },
      1200: {
        slidesPerView: 3,
        loop: false,
      },
    },
  }
    var swiper = new Swiper(".blogs_swiper",data);
    jQuery(window).resize(function(){       
       jQuery('.blogs_swiper_prev,.blogs_swiper_next').removeClass('swiper-button-lock');
       swiper.destroy();
       swiper = new Swiper(".blogs_swiper",data);
    });
{% endjavascript %}
