<div class="inspiration_banner position-relative bg_cover">
  <div class="container position-relative">
    <a href="{{ shop.url }}" class="product_back_btn">{% render 'icon-back' %}</a>
    <div class="inspiration_content">
      <h1 class="mb-0">{{ section.settings.title }}</h1>
    </div>
  </div>
</div>
{% render 'cb-style' %}
{% assign desk_image = section.settings.image | img_url: 'master' %}
{% if section.settings['image-mobile'].size != blank %}
  {% assign mob_image = section.settings['image-mobile'] | img_url: 'master' %}
{% else %}
  {% assign mob_image = section.settings.image | img_url: 'master' %}
{% endif %}

<style>
  .inspiration_banner {
    background-image: url({{ mob_image }});
  }
  @media (min-width: 768px) {
    .inspiration_banner {
      background-image: url({{ desk_image }});
    }
  }
</style>
