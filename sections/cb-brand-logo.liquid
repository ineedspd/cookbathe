<div class="brand_wrapper position-relative">
  <div class="container">
    {% render 'cb-title-option' %}
    <div class="brand_listing">
      {% assign brand = section.blocks | where: 'type', 'brand' %}
      <ul class="list-unstyled d-flex flex-wrap align-items-center justify-content-between justify-content-sm-center">
        {% for block in brand %}
          <li class="brand_item">
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="brand_link">
            {% endif %}  
              <img src="{{ block.settings.logo | img_url:"master" }}" alt="{{ block.settings.logo.alt }}" loading="lazy">
            {% if block.settings.link != blank %}  
              </a>
            {% endif %}  
          </li>
        {% endfor %}        
      </ul>
    </div>
  </div>
</div>
