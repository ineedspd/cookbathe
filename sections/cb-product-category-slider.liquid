<div class="category_slider_wrapper position-relative">
  <div class="container">    
    {% render 'cb-title-option' %}
  <!-- Swiper -->
  {%  assign category = section.blocks | where: 'type', 'category' %}  
  <div class="category_slider_block" data-count="{{ category.size  }}">
    <div class="swiper category_swiper">
    <div class="swiper-wrapper">
      {% assign count = 0 %}
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'category' %}
            {% assign count = count | plus: 1 %}
            <div class="swiper-slide">
              <a href="{{ block.settings.link }}" class="category_card d-flex flex-column align-items-center justify-content-end">
                <img src="{{ block.settings.icon | img_url :'master' }}" alt="{{ block.settings.name }}" loading="lazy" height="80" width="80">
                <p>{{ block.settings.name }}</p>
              </a>
            </div>
          {% endcase %}
      {% endfor %}  
    </div>  
    <div class="category_swiper_pagination swiper-pagination d-sm-none"></div>
  </div>    
    <div class="category_swiper_next swiper-button-next d-none d-sm-flex">&nbsp;</div>
    <div class="category_swiper_prev swiper-button-prev d-none d-sm-flex">&nbsp;</div>      
  </div>
    
  </div>
</div>
