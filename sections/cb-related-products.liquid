{% if product.collections.size != 0 %}
  <div class="featured_products_wrapper position-relative">
    <div class="container">
      {% render 'cb-title-option' %}

      {% assign number_of_related_products_to_show = 4 %}

      {% assign current_product = product %}
      {% assign current_product_tags = product.collections %}
      {% assign num_limit = 0 %}
      <div class="featured_products_slider">
        <div class="swiper featured_products_swiper" data-num="{{ section.settings.columns_desktop }}">
          <div class="swiper-wrapper">
            {% for collection in current_product_tags limit: 1 %}
              {% assign slug = collection.handle %}
            {% endfor %}
            {% for product in collections[slug].products %}
              {% assign related_product = false %}
              {% unless product.handle == current_product.handle %}
                {% assign related_product = true %}
              {% endunless %}

              {% if related_product == true and num_limit < 4 %}
                <div class="swiper-slide">
                  {%
                    render 'cb-product-card',
                    card_product: product,
                    double_image: section.settings.double_image,
                    variant: section.settings.variant_enable,
                    wishlist: section.settings.wishlist_enable,
                    discount: section.settings.discount_enable,
                    price: section.settings.price_enable,
                    addtocart: section.settings.addtocart,
                  %}
                  {% assign num_limit = num_limit | plus: 1 %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
          <div class="featured_swiper_control d-xl-none">
            <div class="swiper-pagination featured_products_pagination"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endif %}
{% javascript %}
  var num = jQuery('.featured_products_swiper').attr('data-num');
   var product_swiper = new Swiper(".featured_products_swiper", {
    slidesPerView: "auto",
    spaceBetween: 20,
    pagination: {
      el: ".featured_products_pagination",
      clickable: true,
    },
    navigation: {
      nextEl: ".featured_swiper_next",
      prevEl: ".featured_swiper_prev",
    },
    breakpoints: {
      576: {
        slidesPerView: 2,
      },
      768: {
        slidesPerView: 2,
      },
      992: {
        slidesPerView: 3,
      },
      1200: {
        slidesPerView: num,
        spaceBetween: 30,
      },
      1400: {
        slidesPerView: num,
        spaceBetween: 32,
      },
    },
  });
{% endjavascript %}
