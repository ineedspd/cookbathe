<div class="featured_inspiration_wrapper position-relative">
  <div class="container">
    {% if section.settings.title != blank %}
      <div class="title_block position-relative">
        <p class="bg-white mb-0 d-inline-block">{{ section.settings.title }}</p>
      </div>
    {% endif %}
    <div class="row">
      {% assign blog = section.blocks | where: 'type', 'blog' %}
      {% for block in blog %}
        {% assign article = articles[block.settings.inspiration] %}

        <div class="{% if forloop.index == 1  %}col-12{% else %}col-lg-6 col-12{% endif %}">
          <div
            class="featured_inspiration_card bg_cover position-relative d-flex flex-wrap flex-md-nowrap align-items-end justify-content-center justify-content-md-start"
            style="background-image: url({{ article.image | img_url: 'master' }});"
          >
            <div
              class="featured_inspiration_card_cover_mobile bg_cover w-100 d-md-none"
              style="background-image: url({{ article.image | img_url: 'master' }});"
            >
              <img
                src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/featured_inspiration_card_cover_mobile.png"
                alt="{{ article.title }}"
                class="w-100"
              >
            </div>
            <div class="featured_inspiration_card_content bg-white">
              <h5>{{ article.title }}</h5>
              <p>{{ article.content | strip_html | truncate: 70, ' ...' }}</p>
              <a href="{{ article.url }}" class="btn btn-outline-primary">Get Inspired</a>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
