{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'collapsible-content.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="accordion_wrapper section-{{ section.id }}-padding">
  <div class="container">  
    {% if  section.blocks.size > 0 %}
    {%- if section.settings.heading != blank -%}
      <div class="section_head_holder d-flex {% if section.settings.text-style == 'center' %}section_head_center_holder align-items-md-center justify-content-md-center{% endif %}">
        <{{ section.settings.heading-tag }} class="h3">{{ section.settings.heading | escape }}</{{ section.settings.heading-tag }}>
      </div>
    {%- else -%}
      <h2 class="visually-hidden">{{ 'accessibility.collapsible_content_title' | t }}</h2>
    {% endif %}
     {% endif %}
    <div class="accordion" id="accordion">
      {%- for block in section.blocks -%}
      <div class="accordion-item" {{ block.shopify_attributes }}>
        <h2 class="accordion-header">
          <button 
            class="accordion-button {% if section.settings.open_first_accordion_row == false or forloop.first == false %}collapsed{% endif %}" 
            type="button" 
            data-bs-toggle="collapse" 
            data-bs-target="#collapse-{{ block.id }}-{{ section.id }}" 
            aria-expanded="{% if section.settings.open_first_accordion_row and forloop.first %}true{% else %}false{% endif %}" 
            aria-controls="collapse-{{ block.id }}-{{ section.id }}">
            {{ block.settings.heading | default: block.settings.page.title }}
          </button>
        </h2>
        <div id="collapse-{{ block.id }}-{{ section.id }}" 
          class="accordion-collapse collapse {% if section.settings.open_first_accordion_row and forloop.first %}show{% endif %}" 
          data-bs-parent="#accordion">
          <div class="accordion-body">
            {{ block.settings.row_content }}
          </div>
        </div>
      </div>
      {%- endfor -%}
    </div>
  </div>
</div>
{%- comment -%}
  FAQ Schema generation
  Only outputs if accordion blocks exist and contain content
{%- endcomment -%}

{% assign faq_blocks = section.blocks | where: "type", "accordion_item" %}

{% if faq_blocks.size > 0 %}
  {% assign has_faq_content = false %}
  {% for block in faq_blocks %}
    {% if block.settings.heading != blank and block.settings.row_content != blank %}
      {% assign has_faq_content = true %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if has_faq_content %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "name": "FAQPage",
      "mainEntity": [
        {%- for block in faq_blocks -%}
          {%- if block.settings.heading != blank and block.settings.row_content != blank -%}
          {
            "@type": "Question",
            "name": {{ block.settings.heading | strip_html | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ block.settings.row_content | strip_html | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
    </script>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "CB Accordion",
  "tag": "section",
  "class": "cb_accordion_section section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collapsible_content.settings.heading.label",
      "default": "Accordion content"
    },
    {
            "type":"select",
            "id":"heading-tag",
            "options":[
              {
                "label":"Paragraph",
                "value":"p"
              },
              {
                "label":"H1",
                "value":"h1"
              },
              {
                "label":"H2",
                "value":"h2"
              },
              {
                "label":"H3",
                "value":"h3"
              },
              {
                "label":"H4",
                "value":"h4"
              },
              {
                "label":"H5",
                "value":"h5"
              },
              {
                "label":"H6",
                "value":"h6"
              }      
            ],
            "label":"Heading Tag",
            "default":"h2"
          },
    {
      "type":"select",
      "options": [
                    {
                      "label": "Left",
                      "value": "left"
                    },
                    {
                      "label": "Center",
                      "value": "center"
                    }
      ],
      "id":"text-style",
      "label":"Title Align"
    },
    {
      "type": "checkbox",
      "id": "open_first_accordion_row",
      "default": false,
      "label": "Open first Accordion row"
    },    
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "accordion_item",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Accordion Item",
          "label": "t:sections.collapsible_content.blocks.collapsible_row.settings.heading.label",
          "info": "t:sections.collapsible_content.blocks.collapsible_row.settings.heading.info"
        },
        {
          "type": "richtext",
          "id": "row_content",
          "label": "t:sections.collapsible_content.blocks.collapsible_row.settings.row_content.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CB Accordion",
      "blocks": [
        {
          "type": "accordion_item"
        },
        {
          "type": "accordion_item"
        },
        {
          "type": "accordion_item"
        },
        {
          "type": "accordion_item"
        }
      ]
    }
  ]
}
{% endschema %}
