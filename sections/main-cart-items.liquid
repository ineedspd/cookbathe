{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}
<div class="cart_banner bg_cover" style="background-image: url({{ section.settings.image | img_url:'master' }});">
  <img
    src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/cart-banner-cover.png"
    alt="cart-banner"
    class="d-none d-md-block mx-auto"
  >
  <img
    src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/cart-banner-mobile-cover.png"
    alt="cart-banner"
    class="d-md-none mx-auto"
  >
</div>
<div class="cart_items_listing_wrapper position-relative {% if cart == empty %} is-empty{% endif %}">
  <div class="container">
    <div class="cart_items_listing_content">
      <div class="row">
        {%- if cart != empty -%}
          <div class="col-lg-7 col-12">
            <div class="cart_products_block">
              <h1 class="h5">{{ 'sections.cart.title' | t }}</h1>
              <div class="cart_products_listing">
                {%- for item in cart.items -%}
                  <div class="cart_products_card">
                    <div class="cart_products_img">
                      <span class="cart_products_card_label">Item</span>
                      <div
                        class="cart_products_cover bg_cover"
                        style="background-image:url({{ item.image | image_url: width: 300 }})"
                      >
                        <a href="{{ item.url }}">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/cart-product-cover.png"
                            alt="{{ item.product.title | escape }}"
                          >
                        </a>
                      </div>
                    </div>
                    <div class="cart_products_name">
                      <span class="cart_products_card_label">Description</span>
                      <a href="{{ item.url }}">{{ item.product.title | escape }}</a>
                      {%- if item.product.has_only_default_variant == false
                        or item.properties.size != 0
                        or item.selling_plan_allocation != null
                      -%}
                        <dl>
                          {%- if item.product.has_only_default_variant == false -%}
                            {%- for option in item.options_with_values -%}
                              <div class="product-option">
                                <dt>{{ option.name }}:</dt>
                                <dd>{{ option.value }}</dd>
                              </div>
                            {%- endfor -%}
                          {%- endif -%}

                          {%- for property in item.properties -%}
                            {%- assign property_first_char = property.first | slice: 0 -%}
                            {%- if property.last != blank and property_first_char != '_' -%}
                              <div class="product-option">
                                <dt>{{ property.first }}:</dt>
                                <dd>
                                  {%- if property.last contains '/uploads/' -%}
                                    <a href="{{ property.last }}" class="link" target="_blank">
                                      {{ property.last | split: '/' | last }}
                                    </a>
                                  {%- else -%}
                                    {{ property.last }}
                                  {%- endif -%}
                                </dd>
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                        </dl>
                        <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                      {%- endif -%}
                    </div>
                    <div class="cart_products_qty">
                      <span class="cart_products_card_label">Qty</span>
                      {%- if item.product.template_suffix == 'tile' -%}
                        <input
                          type="number"
                          class="form-control cart-qty-input"
                          aria-label="Quantity"
                          data-id="{{ item.id }}"
                          value="{{ item.quantity }}"
                          min="1"
                          style="width:80px;"
                        >
                      {%- else -%}
                        {%- assign qty_limit = item.quantity | at_least: 10 -%}
                        <select class="form-select cart-qty-select" aria-label="Quantity" data-id="{{ item.id }}">
                          {%- for i in (1..qty_limit) -%}
                            <option value="{{ i }}" {% if i == item.quantity %}selected{% endif %}>{{ i }}</option>
                          {%- endfor -%}
                        </select>
                      {%- endif -%}
                    </div>
                    <div class="cart_products_unit_price">
                      <span class="cart_products_card_label">Unit Price</span>
                      {{ item.original_price | times:1 | money }}
                    </div>
                    <div class="cart_products_subtotal">
                      <span class="cart_products_card_label">Subtotal</span>
                      {{ item.final_line_price | times:1 | money }}
                    </div>
                    <a href="{{ item.url_to_remove }}" class="remove_product">{% render 'icon-close' %}</a>
                  </div>                  
                {% endfor %}
              </div>
            </div>
          </div>
          <div class="col-lg-5 col-12">
            <div class="order_summary_block">
              <h5>Order Summary</h5>
              {% comment %}
                <div class="coupon_block code_block">
                  {% render 'icon-coupon' %}
                  <input type="text" placeholder="Insert coupon code here">
                </div>
                <div class="postal_block code_block">
                  {% render 'icon-fast-truck' %}
                  <input type="text" placeholder="Insert Postal Code">
                </div>
              {% endcomment %}
              <div class="subtotal_gst_shipping">
                <ul class="list-unstyled">
        
                  {% assign gst = cart.total_price | times: section.settings.gst | divided_by: 100 %}
                  <li class="subtotal_item d-flex align-items-center justify-content-between">
                    <span class="cart_label">Subtotal</span>
                    <span class="cart_digit">{{ cart.total_price | money }}</span>
                  </li>
                  <li class="gst_item d-flex align-items-center justify-content-between">
                    {% assign gst = cart.total_price | times: section.settings.gst | divided_by: 100 %}
                    <span class="cart_label">GST</span><span class="cart_digit">{{ gst | money }}</span>
                  </li>
                  {% comment %}
                    <li class="shipping_item d-flex align-items-center justify-content-between">
                      <span class="cart_label">Shipping</span><span class="cart_digit">$12</span>
                    </li>
                  {% endcomment %}
                </ul>
              </div>
              <div class="total_item d-flex align-items-center justify-content-between">
                <span class="total_label">Total</span>
                <span class="total_degit">{{ cart.total_price | times:1 | money }}</span>
              </div>
              <div class="checkout_cta">
                <!-- Route Code Edited 11/13/2024 -->
                <div class="route-div" desktop-align="center" data-allow-multiple-renders></div>
                <style>
                	route-protect-widget:not([payer='no_coverage']) .pw-container::after {
                	content: "*Enjoy extra peace of mind with optional shipping protection – covering you against loss, theft, or damage in transit.";
                	white-space: pre-wrap;
                	display: inline-block;
                	text-align: center;
                	font-size: 12px !important;
                	}
                </style> 
                <!-- End Route Code -->
                <form action="{{ routes.cart_url }}" method="post" id="cart-notification-form">
                  <button
                    type="submit"
                    id="checkout"
                    class="btn-checkout btn btn-primary w-100"
                    name="checkout"
                  >
                    {% render 'icon-check' %} Checkout
                  </button>
                </form>
              </div>
            </div>
          </div>
        {% else %}
          <div class="cart__warnings">
            <h1 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h1>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary btn-lg">
              {{ 'general.continue_shopping' | t }}
            </a>

            {%- if shop.customer_accounts_enabled and customer == null -%}
              <h2 class="cart__login-title">{{ 'sections.cart.login.title' | t }}</h2>
              <p class="cart__login-paragraph">
                {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
              </p>
            {%- endif -%}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "settings": [
    {
      "type":"image_picker",
      "id":"image",
      "label":"Image"
    },
    {
      "type":"text",
      "id":"gst",
      "label":"Add GST",
      "default":"10"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}