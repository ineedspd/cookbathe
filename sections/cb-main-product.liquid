                  </a>
                    <img
                      src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/main-product-cover.png"
                      alt="{{ image.alt }}" loading="lazy"
                    >
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
          <div class="swiper gallery_thumbs">
            <div class="swiper-wrapper">
              {% for image in product.media %}
                <div class="swiper-slide">
                  <div
                    class="gallery_thumb_card bg_cover lazy-bg" data-bg="{{ image | img_url:'_100' }}"
                  
                  >
                    &nbsp;
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>

           <!-- Swiper Navigation Buttons -->
           <div class="gallery_main_next swiper-button-next"></div>
           <div class="gallery_main_prev swiper-button-prev"></div>
          
        </div>
      </div>
      <div class="col-xl-5 col-lg-6 col-12">
        <div class="product_info_block position-relative">
          <div class="wishlist_share d-none d-md-flex">            
            {% render 'wishlisthero-collection-product' with product: product %}
            {% comment %}
            <button
              type="button"
              class="product_share border-0 p-0 bg-white"
              data-bs-toggle="modal"
              data-bs-target="#ShareModal"
            >
              {% render 'icon-share' %}
            </button>
            {% endcomment %}
            <!-- popover start -->
            <button id="popover-btn" type="button" class="product_share border-0 p-0 bg-white" data-bs-toggle="popover" data-bs-title="Share this product">{% render 'icon-share' %}</button>
            <div hidden >
                <div data-name="popover-content">
                  <div class="blog_article_share_block">
                      <ul class="list-unstyled d-flex align-items-center">
                        <li class="mb-0">
                          <a
                            href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&description={{ product.title }}"
                            target="_blank"
                          >
                            {%- render 'ic-social-pinterest' -%}
                          </a>
                        </li>
                        <li class="mb-0">
                          <a
                            href="https://www.facebook.com/sharer.php?u={{ shop.url }}{{ product.url }}&p={{ product.title }}"
                            target="_blank"
                          >
                            {%- render 'ic-social-facebook' -%}
                          </a>
                        </li>
                        <li class="mb-0">
                          <a
                            href="https://www.linkedin.com/shareArticle?url={{ shop.url }}{{ product.url }}&title={{ product.title }}&summary={{ product.excerpt }}>"
                            target="_blank"
                          >
                            {%- render 'icon-linkedin' -%}
                          </a>
                        </li>
                      </ul>
                </div>
            </div>
          </div>
          <!-- popover end -->
            
            

            <!-- end popup -->
          </div>
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'title' %}
                <h1 class="display-3 d-none d-md-block">{{ product.title }}</h1>
                {%- assign current_variant = product.selected_or_first_available_variant -%}
                <small class="mb-4 d-inline-block"><strong>SKU:</strong> <span id="variant-sku">{{ current_variant.sku }}</span></small>
              {% when 'price' %}
                <div class="price_block price_sale_block">
                  {% if product.compare_at_price != blank and product.compare_at_price != 0 %}
                    <span class="regular_price text-decoration-line-through">
                      {{- product.compare_at_price | times: 1 | money -}}
                    </span>                    
                  {% endif %}              
                    {% if product.price == 0 %}
                      Price on Application
                    {% else %}  
                      <span class="{% if product.compare_at_price != blank and product.compare_at_price != 0 %}sale_price{% else %}regular_price{% endif %}">
                        {{- product.price | times: 1 | money -}}
                      </span>
                    {% endif %}
                </div>
              {% when 'afterpay' %}
                <div class="payment_txt_block d-flex align-items-center">
                  {% assign price = product.price | times: 1 | money %}

                  <afterpay-placement
                    data-locale="en_AU"
                    data-currency="AUD"
                    data-amount="{{price}}"
                  ></afterpay-placement>
                  {% comment %}
                    <div class="payment_logo d-flex align-items-center">
                      <a href="#"
                        ><img
                          src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/Logo__Afterpay.svg"
                          alt="Logo__Afterpay"
                      ></a>
                      <a href="#"
                        ><img
                          src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/Logo__PayPal.svg"
                          alt="Logo__PayPal"
                      ></a>
                    </div>
                  {% endcomment %}
                </div>
              
              {% when 'variant' %}
               {% unless product.price == 0 %}
                {% if product.variants.size > 1 or product.metafields.custom.addon_1_label != blank or product.metafields.custom.addon_2_label != blank or product.metafields.custom.addon_3_label != blank  %}
                      <div class="product_colour_variant product_variants_block product_variants_block_new">
                        {% if product.variants.size > 1 %}
                            {% for option in product.options %}
                              {% assign firstloop = forloop.index0 %}
                                <div class="col-12">
                                    <div class="pcv_wrapper position-relative"> 
                                      <div class="pcv_title" id="SingleOptionSelector-{{forloop.index0}}"> {{ option }} </div>
                                      <select     
                                        id="Option-{{ section.id }}-{{ forloop.index0 }}"
                                        name="options[{{ option | escape }}]"
                                        form="{{ product_form_id }}" id="SingleOptionSelector-{{forloop.index0}}" class="single-option-selector single-option-selector-product-template product-form__input variant-select" >
                                      {% capture option_index %}option{{ forloop.index }}{% endcapture %} 
                                      {% assign option_values = product.variants | map: option_index | uniq %}
                                          {% for choice in option_values %}
                                            {% if firstloop == 0 %}
                                              <option  value="{{ choice }}"> {{ choice }} </option>
                                            {% endif %}
                                          {% endfor %}
                                      </select>
                                    </div>  
                                </div>
                            {% endfor %}
                    
                            <select id="ProductSelect-product-template" class="product-form__variants id_select no-js" name="id" data-productid="{{product.id}}">
                            {% for option in product.variants %}
                            <option data-available="{{ option.available }}" value="{{option.id}}" data-sku="{{ option.sku }}" data-value="{{option.title}}" data-price="{{ option.price | times: 1 | money_without_currency }}" data-sale="{{ option.compare_at_price | times: 1 | money_without_currency }}" {% if option.image %} data-image="{{ option.image | img_url: 'master' }}" {% endif %}>{{option.title}}</option>
                            {% endfor %}
                            </select>
                        {% endif %}
                    
                        {% if product.metafields.custom.addon_1_label != blank and product.metafields.custom.addon_1_product != blank %}
                            <div class="col-12">
                                <div class="pcv_wrapper position-relative"> 
                                    <div class="pcv_title">{{ product.metafields.custom.addon_1_label }}</div>
                                    <select class="single-option-selector addonproduct single-option-selector-product-template product-form__input" id="main-addon-product">
                                        <option value="">{{ product.metafields.custom.addon_1_label }}</option>
                                        {% for product_related in product.metafields.custom.addon_1_product.value %}
                                          {% unless product_related.tags contains 'hide-from-addons' %}
                                            {% if product_related.available %}
                                                <option value="{{ product_related.first_available_variant.id }}" data-price="{{ product_related.price | times: 1 | money_without_currency }}" data-sale="{% if product_related.compare_at_price and product_related.compare_at_price > product_related.price %}{{ product_related.compare_at_price | times: 1 | money_without_currency }}{% else %}{{ product_related.price | times: 1 | money_without_currency }}{% endif %}"
                                                data-image="{{ product_related.featured_image | img_url:'master' }}"
                                                {% if product_related.metafields.custom.addons_properties_text != blank %}
                                                  data-proptext="{{ product_related.metafields.custom.addons_properties_text | escape }}"
                                                {% endif %}
                                                >
                                                    {{ product_related.title }}
                                                </option>
                                              {% endif %}
                                            {% endunless %}
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                        {% endif %}
                    
                        {% if product.metafields.custom.addon_2_label != blank and  product.metafields.custom.addon_2_product != blank %}
                          <div class="col-12">
                           <div class="pcv_wrapper position-relative"> 
                            <div class="pcv_title">{{ product.metafields.custom.addon_2_label }}</div>
                                <select  class="single-option-selector addonproduct single-option-selector-product-template product-form__input" id="main-addon-product-2">
                                    <option value="">{{ product.metafields.custom.addon_2_label }}</option>
                                    {% for product_related in product.metafields.custom.addon_2_product.value %}
                                       {% unless product_related.tags contains 'hide-from-addons' %}
                                              <option value="{{ product_related.first_available_variant.id }}" data-price="{{ product_related.price | times: 1 | money_without_currency }}" data-sale="{% if product_related.compare_at_price and product_related.compare_at_price > product_related.price %}{{ product_related.compare_at_price | times: 1 | money_without_currency }}{% else %}{{ product_related.price | times: 1 | money_without_currency }}
                                                {% endif %}"
                                                 data-image="{{ product_related.featured_image | img_url:'master' }}"
                                                {% if product_related.metafields.custom.addons_properties_text != blank %}
                                                  data-proptext="{{ product_related.metafields.custom.addons_properties_text | escape }}"
                                                {% endif %}>
                                                {{ product_related.title }}
                                              </option>
                                            {% endunless %} 
                                      {% endfor %}
                                </select>
                            </div>
                            </div>
                        {% endif %}
                    
                        {% if product.metafields.custom.addon_3_label != blank and  product.metafields.custom.addon_3_product != blank %}
                          <div class="col-12">
                           <div class="pcv_wrapper position-relative"> 
                            <div class="pcv_title">{{ product.metafields.custom.addon_3_label }}</div>
                                <select  class="single-option-selector addonproduct single-option-selector-product-template product-form__input" id="main-addon-product-3">
                                    <option value="">{{ product.metafields.custom.addon_3_label }}</option>
                                        {% for product_related in product.metafields.custom.addon_3_product.value %}
                                           {% unless product_related.tags contains 'hide-from-addons' %}
                                              <option value="{{ product_related.first_available_variant.id }}" data-price="{{ product_related.price | times: 1 | money_without_currency }}" data-sale="{% if product_related.compare_at_price and product_related.compare_at_price > product_related.price %}{{ product_related.compare_at_price | times: 1 | money_without_currency }}{% else %}{{ product_related.price | times: 1 | money_without_currency }}
                                                {% endif %}"
                                                 data-image="{{ product_related.featured_image | img_url:'master' }}"
                                                {% if product_related.metafields.custom.addons_properties_text != blank %}
                                                  data-proptext="{{ product_related.metafields.custom.addons_properties_text | escape }}"
                                                {% endif %}>
                                                {{ product_related.title }}
                                              </option>
                                            {% endunless %} 
                                      {% endfor %}
                                </select>
                            </div>
                            </div>
                       
                        {% endif %}
                      </div>
                {% endif %}
                <div id="variant-data" class="product_variants_block d-flex flex-wrap flex-sm-nowrap justify-content-sm-between">
                  <div class="product_quantity_variant">
                    <div class="variants_label">Quantity</div>
                    {% assign current_variant = product.selected_or_first_available_variant %}
                    {% assign variant_inventory_quantity = current_variant.inventory_quantity | default: 0 %}
                    {% if current_variant.inventory_management and current_variant.inventory_policy != 'continue' and variant_inventory_quantity > 0 and variant_inventory_quantity < 10 %}
                        {% assign qty_limit = variant_inventory_quantity %}
                    {% else %}
                        {% assign qty_limit = 10 %}
                    {% endif %}
                    {% if qty_limit < 1 %}
                        {% assign qty_limit = 1 %}
                    {% endif %}
                   
                    <select
                      class="form-select quantity__input"
                      id="Quantity-{{ section.id }}"
                      aria-label="Quantity"
                      name="quantity"
                      form="{{ product_form_id }}"
                    >
                      {% for i in (1..qty_limit) %}
                        <option
                          value="{{ i }}"
                          {% if i == 1 %}
                            selected
                          {% endif %}
                        >
                          {{ i }}
                        </option>
                      {% endfor %}
                    </select>
                  </div>
                  <div class="product_addcart">
                   <a id="static-specification" target="_blank" data-href="{{ product.first_available_variant.sku | append: '_product_specification_sheet.pdf' | file_url }}"  data-href1="{{ product.first_available_variant.sku | append: '_spec_sheet.pdf' | file_url }}" class=" btn btn-outline-primary d-none">Specification</a>
                    {% assign for_sale = product.metafields.global['for-sale'] | default: '' | strip %}
                    {% if product.available == true %}
                      {% if for_sale != 'No' %}
                        <button
                          id="add-to-cart"
                          data-id="{{ product.first_available_variant.id }}"
                          data-price="{{ product.price | times: 1 | money_without_currency }}"
                          data-sale="{{ product.compare_at_price | times: 1 | money_without_currency }}"
                          data-sku="{{ product.sku }}"
                          class="btn btn-primary add-to-cart"
                        >
                          {% render 'icon-plus' %}
                          <span>Add to Cart</span>
                        </button>
                      {% else %}
                        <button
                          id="enquire"
                          data-id="{{ product.first_available_variant.id }}"
                          class="btn btn-primary add-to-cart"
                          data-bs-toggle="modal"
                          data-bs-target="#enquireModal"
                        >
                          {% comment %}
                            {% render 'icon-plus' %}
                          {% endcomment %}
                          <span>Enquire</span>
                        </button>
                      {% endif %}
                    {% else %}
                      <button
                        id="sold-out"
                        disabled
                        data-id="{{ product.first_available_variant.id }}"
                        class="btn btn-primary add-to-cart"
                      >
                        {% render 'icon-plus' %} Sold Out
                      </button>
                    {% endif %}
                  </div>
                </div>
                {% endunless %}
                <nibble-placeholder product-form-selector="div.main_product_information_wrapper"></nibble-placeholder>
              {% when 'notice' %}
                {% if product.tags contains block.settings.tag_name  %}
                  <div class="notice_description d-flex align-items-center gap-3">
                    <img src="{{ block.settings.icon_option | img_url }}">
                    {{ block.settings.notice }}
                  </div>
                {% endif %}
              {% when 'description' %}
                {% comment %}
                  {% if product.metafields.custom.shipping_text != blank %}
                    <div class="notice_description d-flex align-items-center gap-3">
                    {% if product.metafields.custom.shipping_icon_order_or_ship_ %}{%- render 'icon-order' %}{% else %}{%- render 'icon-shipping' %}{% endif %}
                    {{ product.metafields.custom.shipping_text | metafield_tag }}
                    </div>
                  {% endif %}
                {% endcomment %}
                <div class="product_description">
                  {% comment %} {{ product.content }} {% endcomment %}
                  {% if block.settings.description != blank %}
                    {{ block.settings.description }}
                  {% else %}
                    {{ block.settings.custom_liquid }}
                  {% endif %}
                </div>
              {% when 'showroom' %}
                <div class="product_other_cta d-flex flex-column flex-sm-row">
                  {% if block.settings['btn-name-1'] != blank %}
                    <a href="{{ block.settings.btn-link-1 }}" class="btn btn-outline-primary order-2 order-sm-1">
                      {%- render 'icon-location' -%}
                      {{- block.settings['btn-name-1'] -}}
                    </a>
                  {% endif %}
                  {% if block.settings['btn-name-2'] != blank %}
                    <a href="{{ block.settings['btn-link-2'] }}" class="btn btn-outline-primary order-1 order-sm-2">
                      {%- render 'icon-call' %}
                      {{ block.settings['btn-name-2'] -}}
                    </a>
                  {% endif %}
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

