<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- assign product_form_id = 'product-form-' | append: section.id -%}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
<style>
  @media (max-width: 768px) {
  .product_media_block .swiper-slide a[data-pin-do="buttonBookmark"] {
        position: absolute;
        display: flex;
        right: 2px;
  }
}
</style>
<div class="breadcrumb_wrapper position-relative">
  {% if product.compare_at_price %}<span class="on_sale_item d-md-none">On Sale</span>{% endif %}
  <div class="container">
    <div aria-label="breadcrumb" class="d-flex align-items-center">
      <a
        href="/collections/{{ product.collections[0].title | handle }}"
        class="product_back_btn d-none d-md-inline-block"
      >
        {%- render 'icon-back' -%} 
      </a> 
      {% assign found_breadcrumb = false %}
      
  {% for cls_link in linklists['breadcrumb'].links %}
    {% for sublinks in cls_link.links %}
      {% for cls in product.collections %}
      
        {% if cls.url ==  sublinks.url %}
          {% assign found_breadcrumb = true %}
          {% assign parent_name = cls_link.title %}
          {% assign parent_link = cls_link.url %}
          {% assign child_name = cls.title %}
          {% assign child_link = cls.url %}
        {% endif %}
      {% endfor %}
    {% endfor %}
  {% endfor %}
      {% if found_breadcrumb %}
          <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ shop.url }}">Home</a></li>
      
        <li class="breadcrumb-item">
          <a href="{{ parent_link }}">{{ parent_name }}</a>
        </li>
        <li class="breadcrumb-item">
          <a href="{{ child_link }}">{{ child_name }}</a>
        </li>
        
        <li class="breadcrumb-item active" aria-current="page">{{ product.title }}</li>
      </ol>
      {% else %}
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ shop.url }}">Home</a></li>
        {% if product.collections[0].title  != blank %}
        <li class="breadcrumb-item">
          <a href="{{ product.collections[0].url }}">{{ product.collections[0].title }}</a>
        </li>
        {% endif %}  
        <li class="breadcrumb-item active" aria-current="page">{{ product.title }}</li>
      </ol>
        {% endif %}
    </div>
  </div>
</div>

<div class="main_product_information_wrapper position-relative">
  <div class="container">
    <div class="row">
      <div class="col-xl-7 col-lg-6 col-12">
        <p class="mobile_product_title display-3 d-md-none position-relative h2">{{ product.title }}
        
         <div class="wishlist_share d-md-none">            
            {% render 'wishlisthero-collection-product' with product: product %}
          <!-- popover start -->
            <button id="popover-btn-mobile" type="button" class="product_share border-0 p-0 bg-white" data-bs-toggle="popover" data-bs-title="Share this product">{% render 'icon-share' %}</button>
            <div hidden >
                <div data-name="popover-content">
                  <div class="blog_article_share_block">
                      <ul class="list-unstyled d-flex align-items-center">
                        <li class="mb-0">
                          <a
                            href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&description={{ product.title }}"
                            target="_blank"
                          >
                            {%- render 'ic-social-pinterest' -%}
                          </a>
                        </li>
                        <li class="mb-0">
                          <a
                            href="https://www.facebook.com/sharer.php?u={{ shop.url }}{{ product.url }}&p={{ product.title }}"
                            target="_blank"
                          >
                            {%- render 'ic-social-facebook' -%}
                          </a>
                        </li>
                        <li class="mb-0">
                          <a
                            href="https://www.linkedin.com/shareArticle?url={{ shop.url }}{{ product.url }}&title={{ product.title }}&summary={{ product.excerpt }}>"
                            target="_blank"
                          >
                            {%- render 'icon-linkedin' -%}
                          </a>
                        </li>
                      </ul>
                </div>
            </div>
          </div>
          <!-- popover end -->
        
          </div>
        </p>
      
        <div class="product_media_block">
          {% if product.metafields.custom.enable_lead_free_watermark_image == true %}
            <div class="lead_free_watermark_logo">
              <img src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/watermark-lead-free-logo.svg?v=1750246474" alt="Lead Free watermark logo">
            </div>
          {% endif %}
          <div class="swiper gallery_main">
            <div class="swiper-wrapper">
              {% for image in product.media %}
                <div class="swiper-slide">
                  <div
                    class="gallery_main_card bg_cover lazy-bg w-100 h-100"
                   data-bg="{{ image | img_url:'master' }}"
                  >
                  <a data-pin-do="buttonBookmark" target="_blank" href="https://www.pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ image | img_url: 'master' }}&description={{ product.title }}" style="background:#fff;padding: 5px 10px; border-radius: 5px; box-shadow: 2px 5px 5px #0000001a;">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 42 20" style="
                          pointer-events: none;
                          transition: transform .2s ease;
                          height: auto;
