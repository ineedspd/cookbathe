<div class="on_specs_wrapper position-relative">
    <div class="container">
        <div class="row align-items-start">
            {% for block in section.blocks %}
            <div class="col-lg-3 col-md-6 col-12">
                <div class="specs_box_container text-center">
                    {% if block.settings.spec_ic != blank %}
                    <div class="specs_icon">
                        {% assign image_url = block.settings.spec_ic | img_url: '80x' %}
                        {% assign image_name = image_url | split: '/' | last | split: '.' | first %}
                        <img src="{{ image_url }}" alt="{{ image_name }}">
                    </div>
                    {% endif %}
                    <div class="specs_content">
                        {% if block.settings.spec_title != blank %}
                            <h4> {{ block.settings.spec_title }}</h4>
                        {% endif %}
                        {% if block.settings.spec_info != blank %}
                        <div class="para">
                            {{ block.settings.spec_info }}
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}

        </div>



    </div>
</div>

{% schema %}
{
    "name": "About work",
    "tag": "section",
    "class": "cb_on_specs",
    "settings": [
    ],
    "blocks": [
    {
      "type": "work_block",
      "name": "What we do block",
      "settings": [
        {
          "type": "image_picker",
          "id": "spec_ic",
          "label": "Icon"
        },
        {
            "type":"text",
            "id":"spec_title",
            "label":"Title"
        },
        {
            "type":"richtext",
            "id":"spec_info",
            "label":"Content"
        }
      ]
    }
  ],
    "presets": [
      {
        "name": "About work"
      }
    ]
    }
    {% endschema %}