{% javascript %}
    var swiper = new Swiper(".category_swiper", {
    //loop: true,
    slidesPerView: "auto",
  //  slidesPerView: 2,
    spaceBetween: 20,
    pagination: {
      el: ".category_swiper_pagination",
      clickable: true,
    },
    navigation: {
      nextEl: ".category_swiper_next",
      prevEl: ".category_swiper_prev",
    },
    breakpoints: {
      576: {
        slidesPerView: 2,
      },
      768: {
        slidesPerView: 3,
      },
      992: {
        slidesPerView: 4,
      },
      1200: {
        slidesPerView: 5,
        spaceBetween: 30,
      },
      1440: {
        slidesPerView: 5,
        spaceBetween: 32,
      },
    },
  });
{% endjavascript %}
