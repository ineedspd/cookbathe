<div class="category_slider_wrapper position-relative">
  <div class="container">
    {% render 'cb-title-option' %}

    <!-- Swiper -->

    <div class="category_slider_block">
      <div class="swiper category_swiper">
        <div class="swiper-wrapper">
          {% if product.collections.size > 1 %}
          {% for collection in product.collections %}
            {% if collection.metafields.custom.icon.size != blank %}
              {% assign icon = collection.metafields.custom.icon | img_url: 'master' %}
            {% else %}
              {% assign icon = 'image' | placeholder_svg_tag %}
            {% endif %}
            <div class="swiper-slide">
              <a
                href="{{ collection.url }}"
                class="category_card d-flex flex-column align-items-center justify-content-center"
              >
                {% comment %}
                  {% if collection.metafields.custom.icon.size == blank %}
                    {{ icon }}
                  {% else %}
                    <img src="{{ icon }}" alt="{{ collection.title }}">
                  {% endif %}
                {% endcomment %}
                <p>{{ collection.title }}</p>
              </a>
            </div>
          {% endfor %}
            {% else %}
            {% for collection in collections limit: 12 %}
            {% if collection.metafields.custom.icon.size != blank %}
              {% assign icon = collection.metafields.custom.icon | img_url: 'master' %}
            {% else %}
              {% assign icon = 'image' | placeholder_svg_tag %}
            {% endif %}
            <div class="swiper-slide">
              <a
                href="{{ collection.url }}"
                class="category_card d-flex flex-column align-items-center justify-content-center"
              >
                {% comment %}
                  {% if collection.metafields.custom.icon.size == blank %}
                    {{ icon }}
                  {% else %}
                    <img src="{{ icon }}" alt="{{ collection.title }}">
                  {% endif %}
                {% endcomment %}
                <p>{{ collection.title }}</p>
              </a>
            </div>
          {% endfor %}
            {% endif %}
        </div>
        <div class="category_swiper_pagination swiper-pagination d-sm-none"></div>
      </div>
      <div class="category_swiper_next swiper-button-next d-none d-sm-flex">&nbsp;</div>
      <div class="category_swiper_prev swiper-button-prev d-none d-sm-flex">&nbsp;</div>
    </div>
  </div>
</div>
