<div class="blog_banner position-relative bg_cover">
  <img src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/blog-page-banner-mobile-cover.png" alt="{{ section.settings['sub-title'] }}" class="d-md-none">
  <div class="container">
    <div class="blog_content bg-white">
      {% if section.settings.title != blank %}
        <p>{{ section.settings.title }}</p>
      {% endif %}
      {% if section.settings['sub-title'] != blank %}
        <h1 class="mb-0">{{ section.settings['sub-title'] }}</h1>
      {% endif %}
    </div>
  </div>
</div>

{% render 'cb-style' %}
{% assign desk_image = section.settings.image | img_url: 'master' %}
{% if section.settings['image-mobile'].size != blank %}
  {% assign mob_image = section.settings['image-mobile'] | img_url: 'master' %}
{% else %}
  {% assign mob_image = section.settings.image | img_url: 'master' %}
{% endif %}
<style>
  .blog_banner {
    background-image: url({{ mob_image }});
  }
  @media (min-width: 768px) {
    .blog_banner {
      background-image: url({{ desk_image }});
    }
  }
</style>
