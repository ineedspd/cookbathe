{% javascript %}
  var loop_check = true;
  var swiper = new Swiper(".gallery_swiper", {
  loop: loop_check,
  slidesPerView: 2,
  spaceBetween: 12,
  centeredSlides: true,
  pagination: {
    el: ".gallery_swiper_pagination",
    clickable: true,
  },
  navigation: {
    nextEl: ".gallery_swiper_next",
    prevEl: ".gallery_swiper_prev",
  },
  breakpoints: {
    768: {
      slidesPerView: 2.4,
    },
    992: {
      slidesPerView: 3.4,
    },
    1200: {
      slidesPerView: 3.4,
    },
    1500: {       
      slidesPerView: 5.4,
    },
  },
});    
{% endjavascript %}