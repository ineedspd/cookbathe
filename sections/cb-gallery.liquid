<div class="gallery_wrapper position-relative overflow-hidden">
  <div class="{{ section.settings.layout }}">
    {% render 'cb-title-option' %}
    {%  assign gallery = section.blocks | where: 'type', 'gallery' %}  
    <div class="gallery_blocks" data-count="{{ gallery.size  }}">
      <div class="swiper gallery_swiper">
        <div class="swiper-wrapper">
          {% assign count = 0 %}
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'gallery' %}
                {% assign count = count | plus: 1 %}
                <div class="swiper-slide">
                  <div class="gallery_card bg_cover" style="background-image: url({{ block.settings.image | img_url :'master' }});">
                    <img src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/gallery-cover.png?v=1732017561" alt="{{ block.settings.image | file_name | remove: 'files/' | split: '.' | first | remove: '-' | remove: '_' | downcase }}">
                  </div>
                </div>
              {% endcase %}
          {% endfor %}  
        </div>
      </div>
    </div>
  </div>
</div>

