<div class="brand_slider_wrapper position-relative brand_slider_{{ template.suffix }}">
  <div class="container">
      <div class="brand_slider_title text-center section_head_holder section_head_center_holder">
          <h2 class="h3">{{section.settings.title}}</h2>
      </div>
  </div>
    <div class="brand_slider_container {% if section.settings.full_slider%}brand_full_slider{% else %}container{% endif %}">

        <div class="swiper {% if section.settings.full_slider%}brandSliderFull{% else %}brandSlider{% endif %}">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
          <div class="swiper-slide d-flex align-items-center">
            <div class="brand_box">
              <img src="{{block.settings.brand_img | img_url : 'master'}}"
              alt="{{ block.settings.brand_img | split: '/' | last | split: '.' | first | default: 'Brand' }}" width="100%" height="100%">
            </div>
          </div>
          {% endfor %}
        </div>
        <div class="swiper-pagination"></div>
      </div>

    </div>

</div>
{% schema %}
  {
    "name": "Brand slider",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "checkbox",
        "id": "full_slider",
        "label": "Full width slider",
        "default": false,
      }
    ],
    "blocks": [
      {
        "type": "brand_block",
        "name": "Brand block",
        "settings": [
          {
            "type": "image_picker",
            "id": "brand_img",
            "label": "Brand logo"
          }
        ]
      }
  ],
    "presets" : [
      {
        "name" : "Brand slider"
      }
    ]
  }
{% endschema %}