<div class="catalogue_wrapper position-relative">
    <div class="container">
        <div class="catalogue_title">
            <div class="row">
                <div class="col-lg-10 col-12 offset-lg-1">
                    <div class="section_head_holder section_head__text_holder d-flex flex-lg-nowrap flex-wrap flex-md-nowrap align-items-md-end align-items-start">
                        <h6 class="h3">{{section.settings.title}}</h6>
                        <div class="para">
                            {{section.settings.content}}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="catalogue_container">
            <div class="row">
                {% for block in section.blocks %}
                <div class="col-xl-4 col-md-6 col-12">
                    <div class="catalogue_box position-relative">

                        {% assign image_url = block.settings.image %}
                        {% assign image_name = image_url | split: '/' | last | split: '.' | first %}
                        <img src="{{ image_url | img_url : '445x' }}" alt="{{ image_name }}" loading="lazy" width="100%" height="100%">

                        {% if block.settings.cat_title != blank or block.settings.cat_link != blank %}
                        <div class="catalogue_content">
                            {% if block.settings.cat_title != blank %}
                                <h4>{{block.settings.cat_title}}</h4>
                            {% endif %}
                            {% if block.settings.cat_link != blank %}
                            <a href="{{block.settings.cat_link}}" class="cat_link d-inline-flex align-items-center">Apply Now
                                <svg xmlns="http://www.w3.org/2000/svg" width="29" height="12" viewBox="0 0 29 12" fill="none">
                                    <path d="M23.2358 1.07178L28.3148 6.16174M28.3148 6.16174L23.2358 11.2517M28.3148 6.16174H1.16833" stroke="#231F20" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </a>
                            {% endif %}
                        </div>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

{% schema %}
  {
    "name": "Catalogue",
    "settings": [
        {
            "type": "text",
            "id": "title",
            "label": "Title"
        },
        {
            "type": "richtext",
            "id": "content",
            "label": "Content"
        }
    ],
    "blocks": [
      {
        "type": "catalogue_block",
        "name": "Catalogue block",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "cat_title",
            "label": "Title"
        },
        {
            "type": "url",
            "id": "cat_link",
            "label": "Link"
        }
        ]
      }
  ],
  "presets" : [
      {
        "name" : "Catalogue"
      }
    ]
  }
{% endschema %}