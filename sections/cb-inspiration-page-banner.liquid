<div class="inspiration_page_banner position-relative bg_cover">
  <div class="container position-relative">
    <a href="{{ blog.url }}" class="product_back_btn">{% render 'icon-back' %}</a>
    <div class="inspiration_page_content bg-white text-center">
      {% if article.metafields.inspiration['tag-line'] != blank %}
        <p class="lead mb-0">{{ article.metafields.inspiration['tag-line'] }}</p>
      {% endif %}
      <h1 class="mb-0 h2">{{ article.title }}</h1>
    </div>
  </div>
</div>

{% assign desk_image = article.image | img_url: 'master' %}
{% if article.metafields.custom.mobile_banner_image != blank %}
  {% assign mob_image = article.metafields.custom.mobile_banner_image | img_url: 'master' %}
{% else %}
  {% assign mob_image = article.image | img_url: 'master'  %}
{% endif %}

<style>
  .inspiration_page_banner {
    background-image: url({{ mob_image }});
  }
  @media (min-width: 768px) {
    .inspiration_page_banner {
      background-image: url({{ desk_image }});
    }
  }
</style>

