<div class="signup_wrapper position-relative overflow-hidden {% if section.settings.mobile-show == false %}mobile_hide_img{% endif %}">
  <div class="container">
    <div class="signup_cover bg_cover {% if section.settings.mobile-show == false %}d-none d-md-block{% endif %} ">
      &nbsp;
    </div>

    <div class="row justify-content-center">
      <div class="col-lg-10 col-12">
        <div class="signup_content_block bg-white d-flex flex-wrap flex-md-nowrap align-items-center justify-content-between">
          <div class="signup_content_inner">
            <div class="section_head_holder d-flex">
              <{{ section.settings.heading-tag }} {% if section.settings.heading-class != 'none' %}class="{{ section.settings.heading-class }}"{% endif %}>{{ section.settings.title }}</{{ section.settings.heading-tag }}>
            </div>
            {{ section.settings.description }}
          </div>
          <div class="signup_form_block">
            <!-- Begin Mailchimp Signup Form -->
            <div id="mc_embed_signup">
              <form
                action="https://cookandbathe.us17.list-manage.com/subscribe/post?u=fd365139b58b749f9dac3767a&amp;id=f72d799bd8&amp;f_id=007398e0f0"
                method="post"
                id="mc-embedded-subscribe-form"
                name="mc-embedded-subscribe-form"
                class="validate subscribe-form"
                target="_self"
              >
                <div id="mc_embed_signup_scroll">
                  <div class="mc-field-group field_group">
                    <label for="mce-LNAME">{% render 'icon-account' %} </label>
                    <input type="text" value="" name="LNAME" class="required" id="mce-LNAME" placeholder="Name">
                    <span id="mce-LNAME-HELPERTEXT" class="helper_text"></span>
                  </div>
                  <div class="mc-field-group field_group">
                    <label for="mce-EMAIL">{% render 'icon-attherate' %}</label>
                    <input type="email" value="" name="EMAIL" class="required email" id="mce-EMAIL" placeholder="Email">
                    <span id="mce-EMAIL-HELPERTEXT" class="helper_text"></span>
                  </div>
                  <div id="mce-responses" class="clear">
                    <div class="response" id="mce-error-response" style="display:none"></div>
                    <div class="response" id="mce-success-response" style="display:none"></div>
                  </div>
                  <!--
                    real people should not fill this in and expect good things - do not remove this or risk form bot signups
                  -->
                  <div style="position: absolute; left: -5000px;" aria-hidden="true">
                    <input type="text" name="b_fd365139b58b749f9dac3767a_f72d799bd8" tabindex="-1" value="">
                  </div>
                  <div class="clear">
                    <input
                      type="submit"
                      value="Sign Up"
                      name="subscribe"
                      id="mc-embedded-subscribe"
                      class="btn btn-outline-primary"
                    >
                  </div>
                </div>
              </form>
            </div>
            <!-- End mc_embed_signup -->
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% render 'cb-style' %}
{% assign desk_image = section.settings.image | img_url: 'master' %}
{% if section.settings['image-mobile'].size != blank %}
  {% assign mob_image = section.settings['image-mobile'] | img_url: 'master' %}
{% else %}
  {% assign mob_image = section.settings.image | img_url: 'master' %}
{% endif %}

<style>
  .signup_cover {
    background-image: url({{ mob_image }});
  }
  @media (min-width: 768px) {
    .signup_cover {
      background-image: url({{ desk_image }});
    }
  }
</style>
