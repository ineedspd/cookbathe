                      </svg>
                    </a>
                    <img src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/main-product-cover.png" alt="{{ image.alt }}" loading="lazy">
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
          <div class="swiper gallery_thumbs">
            <div class="swiper-wrapper">
              {% for image in product.media %}
                <div class="swiper-slide">
                  <div class="gallery_thumb_card bg_cover lazy-bg" data-bg="{{ image | img_url:'_100' }}">&nbsp;</div>
                </div>
              {% endfor %}
            </div>
          </div>
           <!-- Swiper Navigation Buttons -->
           <div class="gallery_main_next swiper-button-next"></div>
           <div class="gallery_main_prev swiper-button-prev"></div>
        </div>
      </div>
      <div class="col-xl-5 col-lg-6 col-12">
        <div class="product_info_block position-relative">
          <div class="wishlist_share d-none d-md-flex">            
            {% render 'wishlisthero-collection-product' with product: product %}
            {% comment %}
            <button
              type="button"
              class="product_share border-0 p-0 bg-white"
              data-bs-toggle="modal"
              data-bs-target="#ShareModal"
            >
              {% render 'icon-share' %}
            </button>
            {% endcomment %}
            <!-- popover start -->
            <button id="popover-btn" type="button" class="product_share border-0 p-0 bg-white" data-bs-toggle="popover" data-bs-title="Share this product">{% render 'icon-share' %}</button>
            <div hidden >
                <div data-name="popover-content">
                  <div class="blog_article_share_block">
                      <ul class="list-unstyled d-flex align-items-center">
                        <li class="mb-0">
                          <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&description={{ product.title }}" target="_blank">
                            {%- render 'ic-social-pinterest' -%}
                          </a>
                        </li>
                        <li class="mb-0">
                          <a href="https://www.facebook.com/sharer.php?u={{ shop.url }}{{ product.url }}&p={{ product.title }}" target="_blank">
                            {%- render 'ic-social-facebook' -%}
                          </a>
                        </li>
                        <li class="mb-0">
                          <a href="https://www.linkedin.com/shareArticle?url={{ shop.url }}{{ product.url }}&title={{ product.title }}&summary={{ product.excerpt }}" target="_blank">
                            {%- render 'icon-linkedin' -%}
                          </a>
                        </li>
                      </ul>
                </div>
            </div>
          </div>
          <!-- popover end -->
          <!-- end popup -->
          </div>
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'title' %}
                <h1 class="display-3 d-none d-md-block js-tile-product-title" data-product-title="{{ product.title | escape }}">{{ selected_tile_display_title }}</h1>
                {%- assign current_variant = selected_tile_variant -%}
                <small class="mb-4 d-inline-block"><strong>SKU:</strong> <span id="variant-sku">{{ current_variant.sku }}</span></small>

              {% when 'price' %}
              <div class="price_block price_sale_block">
                {% if product.compare_at_price != blank and product.compare_at_price != 0 %}
                  <span class="regular_price text-decoration-line-through">
                    {{- product.compare_at_price | times: 1 | money -}}
                  </span>                    
                {% endif %}              
                  {% if product.price == 0 %}
                    Price on Application
                  {% else %}  
                    <span class="{% if product.compare_at_price != blank and product.compare_at_price != 0 %}sale_price{% else %}regular_price{% endif %}">
                      {{- product.price | times: 1 | money -}}
                    </span>
                  {% endif %}
              </div>

              <div class="price_block custom_price_block mt-4 fs-1">
                <!-- PRICE PER SQM -->
                <div class="price_per_sqm" id="price-per-sqm">
                  {% if selected_tile_sqm_per_box_number > 0 %}
                    {{ selected_tile_variant.price | divided_by: selected_tile_sqm_per_box_number | money }}
                    <span>per sqm</span>
                  {% else %}
                    <span>per sqm unavailable</span>
                  {% endif %}
                </div>
                <!-- PRICE PER BOX -->
                <div class="price_per_box text-muted" id="price-per-box">
                  {{ selected_tile_variant.price | money }}
                  <span>per box</span>
                </div>
              </div>

                
              {% when 'afterpay' %}
              <div class="payment_txt_block d-flex align-items-center">
                {% assign price = product.price | times: 1 | money %}
                <afterpay-placement data-locale="en_AU" data-currency="AUD" data-amount="{{price}}"></afterpay-placement>
                {% comment %}
                  <div class="payment_logo d-flex align-items-center">
                    <a href="#"><img src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/Logo__Afterpay.svg" alt="Logo__Afterpay"></a>
                    <a href="#"><img src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/Logo__PayPal.svg" alt="Logo__PayPal"></a>
                  </div>
                {% endcomment %}
              </div>
              
              {% when 'variant' %}
               {% unless product.price == 0 %}
                {% if product.variants.size > 1 or product.metafields.custom.addon_1_label != blank or product.metafields.custom.addon_2_label != blank or product.metafields.custom.addon_3_label != blank  %}
                      <div class="product_colour_variant product_variants_block product_variants_block_new">
                        {% if product.variants.size > 1 %}
                            {% for option in product.options %}
                              {% assign firstloop = forloop.index0 %}
                                <div class="col-12">
                                    <div class="pcv_wrapper position-relative"> 
                                      <div class="pcv_title" id="SingleOptionSelector-{{forloop.index0}}"> {{ option }} </div>
                                      <select     
                                        id="Option-{{ section.id }}-{{ forloop.index0 }}"
                                        name="options[{{ option | escape }}]"
                                        form="{{ product_form_id }}" id="SingleOptionSelector-{{forloop.index0}}" class="single-option-selector single-option-selector-product-template product-form__input variant-select" >
                                      {% capture option_index %}option{{ forloop.index }}{% endcapture %} 
                                      {% assign option_values = product.variants | map: option_index | uniq %}
                                      {% assign selected_option_value = selected_tile_variant.options[firstloop] %}
                                          {% for choice in option_values %}
                                            <option value="{{ choice }}" {% if choice == selected_option_value %}selected="selected"{% endif %}> {{ choice }} </option>
                                          {% endfor %}
                                      </select>
                                    </div>  
                                </div>
                            {% endfor %}
                    
                            <select id="ProductSelect-product-template" class="product-form__variants id_select no-js" name="id" data-productid="{{product.id}}">
                            {% for option in product.variants %}
                            <option
                              data-available="{{ option.available }}"
                              value="{{option.id}}"
                              data-sku="{{ option.sku }}"
                              data-value="{{option.title}}"
                              data-title="{{ option.title | escape }}"
                              data-url="{{ product.url }}?variant={{ option.id }}"
                              data-price="{{ option.price | times: 1 | money_without_currency }}"
                              data-sale="{{ option.compare_at_price | times: 1 | money_without_currency }}"
                              data-variant-sqm="{{ option.metafields.custom.variant_price_per_sqm.value | default: product_price_per_sqm }}"
                              data-variant-sqm-box="{{ option.metafields.custom.variant_sqm_per_box.value | default: product_sqm_per_box }}"
                              {% if option.image %} data-image="{{ option.image | img_url: 'master' }}" {% endif %}
                              {% if option.id == selected_tile_variant.id %}selected="selected"{% endif %}
                            >{{option.title}}</option>
                            {% endfor %}
                            </select>
                        {% endif %}
                    
                        {% if product.metafields.custom.addon_1_label != blank and product.metafields.custom.addon_1_product != blank %}
                            <div class="col-12">
                                <div class="pcv_wrapper position-relative"> 
                                    <div class="pcv_title">{{ product.metafields.custom.addon_1_label }}</div>
                                    <select class="single-option-selector addonproduct single-option-selector-product-template product-form__input" id="main-addon-product">
                                        <option value="">{{ product.metafields.custom.addon_1_label }}</option>
                                        {% for product_related in product.metafields.custom.addon_1_product.value %}
                                          {% unless product_related.tags contains 'hide-from-addons' %}
                                            {% if product_related.available %}
                                                <option value="{{ product_related.first_available_variant.id }}" data-price="{{ product_related.price | times: 1 | money_without_currency }}" data-sale="{% if product_related.compare_at_price and product_related.compare_at_price > product_related.price %}{{ product_related.compare_at_price | times: 1 | money_without_currency }}{% else %}{{ product_related.price | times: 1 | money_without_currency }}{% endif %}"
                                                data-image="{{ product_related.featured_image | img_url:'master' }}"
                                                {% if product_related.metafields.custom.addons_properties_text != blank %}
                                                  data-proptext="{{ product_related.metafields.custom.addons_properties_text | escape }}"
                                                {% endif %}
                                                >
                                                    {{ product_related.title }}
                                                </option>
                                              {% endif %}
                                            {% endunless %}
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                        {% endif %}
                    
                        {% if product.metafields.custom.addon_2_label != blank and  product.metafields.custom.addon_2_product != blank %}
                          <div class="col-12">
                           <div class="pcv_wrapper position-relative"> 
                            <div class="pcv_title">{{ product.metafields.custom.addon_2_label }}</div>
                                <select  class="single-option-selector addonproduct single-option-selector-product-template product-form__input" id="main-addon-product-2">
                                    <option value="">{{ product.metafields.custom.addon_2_label }}</option>
                                    {% for product_related in product.metafields.custom.addon_2_product.value %}
                                       {% unless product_related.tags contains 'hide-from-addons' %}
                                              <option value="{{ product_related.first_available_variant.id }}" data-price="{{ product_related.price | times: 1 | money_without_currency }}" data-sale="{% if product_related.compare_at_price and product_related.compare_at_price > product_related.price %}{{ product_related.compare_at_price | times: 1 | money_without_currency }}{% else %}{{ product_related.price | times: 1 | money_without_currency }}
                                                {% endif %}"
                                                 data-image="{{ product_related.featured_image | img_url:'master' }}"
                                                {% if product_related.metafields.custom.addons_properties_text != blank %}
                                                  data-proptext="{{ product_related.metafields.custom.addons_properties_text | escape }}"
                                                {% endif %}>
                                                {{ product_related.title }}
                                              </option>
                                            {% endunless %} 
                                      {% endfor %}
                                </select>
                            </div>
                            </div>
                        {% endif %}
                    
                        {% if product.metafields.custom.addon_3_label != blank and  product.metafields.custom.addon_3_product != blank %}
                          <div class="col-12">
                           <div class="pcv_wrapper position-relative"> 
                            <div class="pcv_title">{{ product.metafields.custom.addon_3_label }}</div>
                                <select  class="single-option-selector addonproduct single-option-selector-product-template product-form__input" id="main-addon-product-3">
                                    <option value="">{{ product.metafields.custom.addon_3_label }}</option>
                                        {% for product_related in product.metafields.custom.addon_3_product.value %}
                                           {% unless product_related.tags contains 'hide-from-addons' %}
                                              <option value="{{ product_related.first_available_variant.id }}" data-price="{{ product_related.price | times: 1 | money_without_currency }}" data-sale="{% if product_related.compare_at_price and product_related.compare_at_price > product_related.price %}{{ product_related.compare_at_price | times: 1 | money_without_currency }}{% else %}{{ product_related.price | times: 1 | money_without_currency }}
                                                {% endif %}"
                                                 data-image="{{ product_related.featured_image | img_url:'master' }}"
                                                {% if product_related.metafields.custom.addons_properties_text != blank %}
                                                  data-proptext="{{ product_related.metafields.custom.addons_properties_text | escape }}"
                                                {% endif %}>
                                                {{ product_related.title }}
                                              </option>
                                            {% endunless %} 
                                      {% endfor %}
                                </select>
                            </div>
                            </div>
                       
                        {% endif %}
                      </div>
                {% endif %}
                {% comment %} <div id="variant-data" class="product_variants_block d-flex flex-wrap flex-sm-nowrap justify-content-sm-between">
                  <div class="product_quantity_variant">
                    <div class="variants_label">Quantity</div>
                    {% assign current_variant = product.selected_or_first_available_variant %}     
                    {% if current_variant.inventory_quantity < 10 %}
                        {% assign qty_limit = current_variant.inventory_quantity %}
                    {% else %}
                        {% assign qty_limit = 10 %}
                    {% endif %}  
                   
                    <select class="form-select quantity__input" id="Quantity-{{ section.id }}" aria-label="Quantity" name="quantity" form="{{ product_form_id }}">
                      {% for i in (1..qty_limit) %}
                        <option value="{{ i }}" {% if i == 1 %}selected{% endif %}>{{ i }}</option>
                      {% endfor %}
                    </select>
                  </div>
                  <div class="product_addcart">
                   <a id="static-specification" target="_blank" data-href="{{ product.first_available_variant.sku | append: '_product_specification_sheet.pdf' | file_url }}"  data-href1="{{ product.first_available_variant.sku | append: '_spec_sheet.pdf' | file_url }}" class=" btn btn-outline-primary d-none">Specification</a>
                    {% assign for_sale = product.metafields.global['for-sale'] | default: '' | strip %}
                    {% if product.available == true %}
                      {% if for_sale != 'No' %}
                        <button id="add-to-cart" data-id="{{ product.first_available_variant.id }}" data-price="{{ product.price | times: 1 | money_without_currency }}" data-sale="{{ product.compare_at_price | times: 1 | money_without_currency }}" data-sku="{{ product.sku }}" class="btn btn-primary add-to-cart">
                          {% render 'icon-plus' %}
                          <span>Add to Cart</span>
                        </button>
                      {% else %}
                        <button id="enquire" data-id="{{ product.first_available_variant.id }}" class="btn btn-primary add-to-cart" data-bs-toggle="modal" data-bs-target="#enquireModal">
                          {% comment %}
                            {% render 'icon-plus' %}
                          {% endcomment %}
                          <span>Enquire</span>
                        </button>
                      {% endif %}
                    {% else %}
                      <button id="sold-out" disabled data-id="{{ product.first_available_variant.id }}" class="btn btn-primary add-to-cart">
                        {% render 'icon-plus' %} Sold Out
                      </button>
                    {% endif %}
                  </div>
                </div> {% endcomment %}
                {% endunless %}
                <nibble-placeholder product-form-selector="div.main_product_information_wrapper"></nibble-placeholder>
              {% when 'notice' %}
                {% if product.tags contains block.settings.tag_name  %}
                  <div class="notice_description d-flex align-items-center gap-3">
                    <img src="{{ block.settings.icon_option | img_url }}">
                    {{ block.settings.notice }}
                  </div>
                {% endif %}
              {% when 'description' %}
                {% comment %}
                  {% if product.metafields.custom.shipping_text != blank %}
                    <div class="notice_description d-flex align-items-center gap-3">
                    {% if product.metafields.custom.shipping_icon_order_or_ship_ %}{%- render 'icon-order' %}{% else %}{%- render 'icon-shipping' %}{% endif %}
                    {{ product.metafields.custom.shipping_text | metafield_tag }}
                    </div>
                  {% endif %}
                {% endcomment %}
                <div class="product_description">
                  {% comment %} {{ product.content }} {% endcomment %}
                  {% if block.settings.description != blank %}
                    {{ block.settings.description }}
                  {% else %}
                    {{ block.settings.custom_liquid }}
                  {% endif %}
                </div>
              {% when 'showroom' %}
                <div class="metreage_holder">
                  <h5 class="text-center">Calculate Your Square Metreage</h5>
                  <div class="area_options_block_content">
                    <div class="row">
                      <div class="col-sm-6 col-12">
                        <div id="area-option-known" class="area_options_block_card">
                          <div class="area-option-icon">
                              <img src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/metersquare-ic.svg?v=1774090243" alt="metersquare-ic">
                          </div>
                          <div class="area-option-content">
                              <h6>I know the exact square metreage I require</h6>
                              <p>You already have your square metreage from a professional tradesperson.</p>
                              <a href="javascript:void(0)" id="area-known" class="btn btn-outline-primary gap-2">
                                  Continue {% render 'icon-arrow' %}
                              </a>
                          </div>
                        </div>
                                              
                      </div>
                      <div class="col-sm-6 col-12">
                        <div id="area-option-to-calculate" class="area_options_block_card">
                          <div class="area-option-icon">
                                <img src="https://cdn.shopify.com/s/files/1/0667/0588/3436/files/calculatemetersquare-ic.svg?v=1774090878" alt="calculatemetersquare-ic">
                          </div>
                          <div class="area-option-content">
                              <h6>I need the square metreage calculated for me</h6>
                              <p>Enter the measurements to calculate your square metreage.</p>
                              <a href="javascript:void(0)" id="area-to-calculate" class="btn btn-outline-primary gap-2">
                                  Continue {% render 'icon-arrow' %}
                              </a>
                          </div>
                        </div>
                      </div>
                      <div class="col-12">
                        <div class="your_square_metre d-none" id="input-area">
                          <h6>Enter Your Square Metre</h6>
                          <p>Measurement(square metres)</p>
                          <input class="form-control tile-known-sqm-input" id="area-input" type="text" inputmode="decimal" maxlength="8" placeholder="Enter your measurements in square metres">
                          <div class="wastage_cards_container bg-white rounded p-3 my-3">
                            <div class="wastage_cards_head">
                              <p>We round up your required square metres to the nearest whole box. Additionally, we suggest ordering an extra 15% to cover any wastage that may occur during tile cutting.</p>
                              <p>Selected wastage option: <strong class="wastage_percent">15%</strong>.</p>
                              <div class="wastage_note d-none">
                                <div class="wastage_note_inner d-flex align-items-start gap-2">
                                  <div class="wastage_note_icon">{% render 'icon-info' %}</div>
                                  <p class="mb-0"><strong>Please Note:</strong> You have selected No Wastage, meaning you'll receive no extra tiles for cuts or future damages. We recommend ordering an additional 15% to cover potential wastage during tile-cutting.</p>
                                </div>
                              </div>
                            </div>
                            <div class="row">
                              <div class="col-6">
                                <div class="wastage_card border border-light p-3 rounded text-center">
                                  <input class="form-check-input" type="radio" name="wastage" id="wastage1" value="0">
                                  <strong>No Wastage</strong>
                                </div>
                              </div>
                              <div class="col-6">
                                <div class="wastage_card border border-light p-3 rounded text-center active">
                                  <input class="form-check-input" type="radio" name="wastage" id="wastage2" value="15" checked>
                                  <strong>15%</strong>
                                </div>
                              </div>
                            </div>
                          </div>
                          <div class="measurement_output_wrapper mt-5">
                            <div class="measurement_info_wrapper row">
                              <div class="col-6">
                                <div class="bg-white rounded d-flex flex-column align-items-center justify-content-center p-4 calculated-info-wrapper h-100"> 
                                    <div class="h2 m-0" id="total-option-area-known">0</div>
                                    <hr class="w-50 my-3">     
                                    <p class="mb-0">SQM Needed</p>
                                </div>
                              </div>
                              <div class="col-6">
                                <div class="bg-white rounded d-flex flex-column align-items-center justify-content-center p-4 calculated-info-wrapper h-100"> 
                                    <div class="h2 m-0" id="final-total-option-area-known">0.00</div>
                                    <hr class="w-50 my-3">     
                                    <p class="d-flex gap-2 mb-0"><span>SQM Included</span>
                                    <span class="d-inline-block" tabindex="0" data-bs-toggle="popover" data-bs-trigger="hover focus" data-bs-content="We round up your required square metres to the nearest whole box.">
                                      <button class="border-0 p-0 bg-transparent" type="button">{% render 'icon-info' %}</button>
                                    </span>
                                    </p>
                                </div>
                              </div>
                              <div class="col-6">
                                <div class="bg-white rounded d-flex flex-column align-items-center justify-content-center p-4 calculated-info-wrapper h-100">
                                  <div class="h2 m-0" id="total-box-option-area-known">0</div>
                                  <hr class="w-50 my-3">
                                  <p class="mb-0">Total Boxes</p>        
                                </div>
                              </div>
                              <div class="col-6">
                                <div class="bg-white rounded d-flex flex-column align-items-center justify-content-center p-4 calculated-info-wrapper h-100">
                                    <div class="h2 m-0" id="total-price-option-area-known">$0.00</div>
                                    <hr class="w-50 my-3">
                                    <p class="mb-0">Total Price</p>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                        <div class="calculate_square_metre d-none" id="calculate-area">  
                           <h6>How to Calculate</h6>
                          <p>1 - Measure the length and width of your areas. <br> 2 - Enter the room's measurements below in metres. Add area name / sections.</p>
                          <div class="tile_calculation_areas">
                            <div class="tile_calculation_area_card border rounded p-3 mb-3">
                              <div class="area_holder">
                                <legend>AREA</legend>
                                <input class="form-control tile-area-name-input" type="text" maxlength="40" placeholder="Example: Kitchen">
                              </div>
                              <div class="tile_calculation_area_info d-flex flex-wrap align-items-end justify-content-between gap-3 mt-4">
                                <div class="length_holder">
                                  <legend>LENGTH (m)</legend>
                                  <input class="form-control tile-measurement-input" type="text" inputmode="decimal" maxlength="8" placeholder="0 metre">
                                </div>
                                <span class="d-inline-block mb-3">{{ 'close-ic.svg' | inline_asset_content }}</span>
                                <div class="width_holder">
                                  <legend>WIDTH (m)</legend>
                                  <input class="form-control tile-measurement-input" type="text" inputmode="decimal" maxlength="8" placeholder="0 metre">
                                </div>
                                <span class="equals_item d-inline-block mb-sm-3">{{ 'equal-ic.svg' | inline_asset_content }}</span>
                                <div class="tile_output_holder">
                                  <legend>SQM</legend>
                                  <div class="tile_area_output">0</div>
                                </div>
                                <div class="tile_calculation_area_card_cta d-flex align-items-center gap-3">
                                  <button type="button"class="delete_area_calculator border-0 bg-white rounded">{{ 'delete-ic.svg' | inline_asset_content }}</button>
                                </div>
                              </div>
                            </div>
                            <div class="tile_calculation_areas_cta d-flex justify-content-center gap-3 mt-4">
                              <button type="button" class="add_new_area_calculator btn btn-outline-primary gap-2">Add Room {{ 'plus-ic.svg' | inline_asset_content }}</button>
                              <button type="button" class="calculate_btn btn btn-outline-primary gap-2">Calculate {% render 'icon-arrow' %}</button>
                            </div>
                            <div id="tile-room-calculator-error" class="alert alert-warning mt-3 d-none" role="alert"></div>
                          </div>
                          <div class="wastage_cards_container bg-white rounded p-3 my-3">
                            <div class="wastage_cards_head">
                              <p>We round up your required square metres to the nearest whole box. Additionally, we suggest ordering an extra 15% to cover any wastage that may occur during tile cutting.</p>
                              <p>Selected wastage option: <strong class="wastage_percent">15%</strong>.</p>
                              <div class="wastage_note d-none">
                                <div class="wastage_note_inner d-flex align-items-start gap-2">
                                  <div class="wastage_note_icon">{% render 'icon-info' %}</div>
                                  <small class="mb-0"><strong>Please Note:</strong> You have selected No Wastage, meaning you'll receive no extra tiles for cuts or future damages. We recommend ordering an additional 15% to cover potential wastage during tile-cutting.</small>
                                </div>
                              </div>
                            </div>
                            <div class="row">
                              <div class="col-6">
                                <div class="wastage_card border border-light p-3 rounded text-center">
                                  <input class="form-check-input" type="radio" name="wastage_calc" id="wastagecalc1" value="0">
                                  <strong>No Wastage</strong>
                                </div>
                              </div>
                              <div class="col-6">
                                <div class="wastage_card border border-light p-3 rounded text-center active">
                                  <input class="form-check-input" type="radio" name="wastage_calc" id="wastagecalc2" value="15" checked>
                                  <strong>15%</strong>
                                </div>
                              </div>
                            </div>
                          </div>
                          <div class="measurement_output_wrapper mt-5">
                            <div class="measurement_info_wrapper row">
                              <div class="col-12">
                                <div id="show-calculation-summary"></div>
                              </div>
                              <div class="col-6">
                                <div class="bg-white rounded d-flex flex-column align-items-center justify-content-center p-4 calculated-info-wrapper h-100"> 
                                    <div class="h2 m-0" id="total-option-area-calc">0</div>
                                    <hr class="w-50 my-3">     
                                    <p class="mb-0">SQM Needed</p>
                                </div>
                              </div>
                              <div class="col-6">
                                <div class="bg-white rounded d-flex flex-column align-items-center justify-content-center p-4 calculated-info-wrapper h-100"> 
                                    <div class="h2 m-0" id="final-total-option-area-calc">0.00</div>
                                    <hr class="w-50 my-3">     
                                    <p class="d-flex gap-2 mb-0"><span>SQM Included</span>
                                    <span class="d-inline-block" tabindex="0" data-bs-toggle="popover" data-bs-trigger="hover focus" data-bs-content="We round up your required square metres to the nearest whole box.">
                                      <button class="border-0 p-0 bg-transparent" type="button">{% render 'icon-info' %}</button>
                                    </span>
                                    </p>
                                </div>
                              </div>
                              <div class="col-6">
                                <div class="bg-white rounded d-flex flex-column align-items-center justify-content-center p-4 calculated-info-wrapper h-100">
                                  <div class="h2 m-0" id="total-box-option-area-calc">0</div>
                                  <hr class="w-50 my-3">
                                  <p class="mb-0">Total Boxes</p>        
                                </div>
                              </div>
                              <div class="col-6">
                                <div class="bg-white rounded d-flex flex-column align-items-center justify-content-center p-4 calculated-info-wrapper h-100">
                                    <div class="h2 m-0" id="total-price-option-area-calc">$0.00</div>
                                    <hr class="w-50 my-3">
                                    <p class="mb-0">Total Price</p>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                        <div class="cart_cta">
                          <div id="tile-calculator-error" class="alert alert-warning mt-3 d-none" role="alert"></div>
                          {% unless product.price == 0 %}
                          <div id="variant-data" class="product_variants_block d-flex flex-wrap flex-sm-nowrap justify-content-sm-center border-0 py-0">
                            <div class="product_quantity_variant" id="tile-qty-wrapper" style="display:none;">
                              <div class="variants_label">Quantity</div>
                              <input
                                type="number"
                                class="form-control quantity__input"
                                id="Quantity-{{ section.id }}"
                                aria-label="Quantity"
                                name="quantity"
                                form="{{ product_form_id }}"
                                value="1"
                                min="1"
                                style="width:100px;"
                              >
                            </div>
                            <div class="product_addcart">
                            <a id="static-specification" target="_blank" data-href="{{ product.first_available_variant.sku | append: '_product_specification_sheet.pdf' | file_url }}"  data-href1="{{ product.first_available_variant.sku | append: '_spec_sheet.pdf' | file_url }}" class=" btn btn-outline-primary d-none">Specification</a>
                              {% assign for_sale = product.metafields.global['for-sale'] | default: '' | strip %}
                              {% if product.available == true %}
                                {% if for_sale != 'No' %}
                                  <button
                                    id="add-to-cart"
                                    data-id="{{ selected_tile_variant.id }}"
                                    data-price="{{ selected_tile_variant.price | times: 1 | money_without_currency }}"
                                    data-sale="{{ selected_tile_variant.compare_at_price | times: 1 | money_without_currency }}"
                                    data-sku="{{ selected_tile_variant.sku }}"
                                    class="btn btn-primary add-to-cart"
                                  >
                                    {% render 'icon-plus' %}
                                    <span>Add to Cart</span>
                                  </button>
                                  <span class="cart-btn-loader"></span>
                                {% else %}
                                  <button
                                    id="enquire"
                                    data-id="{{ selected_tile_variant.id }}"
                                    class="btn btn-primary add-to-cart"
                                    data-bs-toggle="modal"
                                    data-bs-target="#enquireModal"
                                  >
                                    {% comment %}
                                      {% render 'icon-plus' %}
                                    {% endcomment %}
                                    <span>Enquire</span>
                                  </button>
                                {% endif %}
                              {% else %}
                                <button
                                  id="sold-out"
                                  disabled
                                  data-id="{{ selected_tile_variant.id }}"
                                  class="btn btn-primary add-to-cart"
                                >
                                  {% render 'icon-plus' %} Sold Out
                                </button>
                              {% endif %}
                            </div>
                          </div>
                          {% endunless %}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="product_other_cta d-flex flex-column flex-sm-row">
                  {% if block.settings['btn-name-1'] != blank %}
                    <a href="{{ block.settings.btn-link-1 }}" class="btn btn-outline-primary order-2 order-sm-1">
                      {%- render 'icon-location' -%}
                      {{- block.settings['btn-name-1'] -}}
                    </a>
                  {% endif %}
                  {% if block.settings['btn-name-2'] != blank %}
                    <a href="{{ block.settings['btn-link-2'] }}" class="btn btn-outline-primary order-1 order-sm-2">
                      {%- render 'icon-call' %}
                      {{ block.settings['btn-name-2'] -}}
                    </a>
                  {% endif %}
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

  <div
    class="product_share_modal modal fade"
    id="enquireModal"
    tabindex="-1"
    aria-labelledby="enquireModal"
    aria-hidden="true"
    data-bs-backdrop="static"
    data-bs-keyboard="false"
  >
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-body">
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          <div class="blog_article_share_block">
            <div class="title_block position-relative">
              <p class="bg-white mb-0 d-inline-block1 text-center h3">Enquire product</p>
            </div>
            <div class="contact_form">
              {% form 'contact', id: 'ContactForm' %}
                {%- if form.posted_successfully? -%}
                  <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
                    {% render 'icon-success' %}
                    {{ 'templates.contact.form.post_success' | t }}
                  </h2>
                {%- elsif form.errors -%}
                  <div class="form__message">
                    <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
                      {% render 'icon-error' %}
                      {{ 'templates.contact.form.error_heading' | t }}
                    </h2>
                  </div>
                  <ul class="form-status-list caption-large" role="list">
                    <li>
                      <a href="#ContactForm-email" class="link">
                        {{ form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email }}
                      </a>
                    </li>
                  </ul>
                {%- endif -%}
                <input type="hidden" class="form-control" id="product-name" name="contact[product_name]" value="{{ product.title }}">
                <input type="hidden" class="form-control" id="product-url" name="contact[product_url]" value="{{ shop.url }}{{ product.url }}">
                <div class="row">
                  <div class="col-lg-12 col-12">
                    <div class="form_group">
                      <label>First Name</label>
                      <input type="text" class="form-control required" id="first-name" name="contact[first_name]">
                    </div>
                  </div>
                  <div class="col-lg-12 col-12">
                    <div class="form_group">
                      <label>Last Name</label>
                      <input type="text" name="contact[last_name]" id="last-name" class="form-control required">
                    </div>
                  </div>
                  <div class="col-lg-12 col-12">
                    <div class="form_group">
                      <label>Email Address</label>
                      <input type="email" class="form-control required email" name="contact[email]" id="email">
                    </div>
                  </div>
      
                  <div class="col-lg-12 col-12">
                    <div class="form_group">
                      <label>Phone Number</label>
                      <input type="tel" name="contact[phone]" id="phone" class="form-control required number phone_limit">
                    </div>
                  </div>
                  <div class="col-lg-12 col-12">
                    <div class="form_group">
                      <label>Message</label>
                      <textarea name="contact[body]" id="message" class="form-control required"></textarea>
                    </div>
                  </div>
                  <div class="col-4 container-fluid">
                    <div class="form_group">
                      <input type="submit" class="btn btn-primary" value="Send Message">
                    </div>
                  </div>
                </div>
              {% endform %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
"name": "Tile Product Information",
"tag": "section",
"class": "cb-main-product",
"settings": [],
"blocks":[
  {
    "type":"title",
    "name":"Title",
    "limit":1,
    "settings":[]
  },
  {
    "type":"price",
    "name":"Price",
    "limit":1,
    "settings":[]
  },
  {
    "type":"afterpay",
    "name":"After Pay",
    "limit":1,
    "settings":[]
  },
  {
    "type":"variant",
    "name":"Variant",
    "limit":1,
    "settings":[]
  },
  {
    "type":"description",
    "name":"Description",
    "limit":1,
    "settings":[
      {
        "type":"richtext",
        "id":"description",
        "label":"Description"
      },
      {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "t:sections.main-product.blocks.custom_liquid.settings.custom_liquid.label",
          "info": "t:sections.main-product.blocks.custom_liquid.settings.custom_liquid.info"
      }
    ]
  },
    {
    "type":"notice",
    "name":"Notice",
    "settings":[
       {
      "type": "image_picker",
      "label": "Item Icon",
      "id": "icon_option"
    },
      {
        "type":"richtext",
        "id":"notice",
        "label":"Notice"
      }
      ,
      {
        "type":"text",
        "id":"tag_name",
        "label":"Tag"
      }
    ]
  },
  {
    "type":"showroom",
    "name":"Showroom Detail",
    "limit":1,
    "settings":[
      {
        "type":"text",
        "id":"btn-name-1",
        "label":"Button Name 1",
        "default":" Locate Showroom"
      },
      {
        "type":"url",
        "id":"btn-link-1",
        "label":"Button Link"
      },
      {
        "type":"text",
        "id":"btn-name-2",
