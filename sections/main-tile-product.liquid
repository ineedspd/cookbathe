// Share product popover
if (window.jQuery) {
$(document).ready(function() {
    if (!window.bootstrap || !bootstrap.Popover) return;

    var shareButtons = [
      document.getElementById('popover-btn'),
      document.getElementById('popover-btn-mobile')
    ].filter(Boolean);

    if (!shareButtons.length) return;

    function getShareContent(button) {
      var wrapper = button.closest('.wishlist_share');
      var content = wrapper ? wrapper.querySelector('[data-name="popover-content"]') : null;
      return content ? content.innerHTML : "";
    }

    function hideProductSharePopovers(exceptButton) {
      shareButtons.forEach(function (button) {
        if (button === exceptButton) return;
        var instance = bootstrap.Popover.getInstance(button);
        if (instance) instance.hide();
      });
    }

    var options = {
        html: true,
        container: 'body',
        customClass: 'product-share-popover',
        trigger: 'click',
        placement: window.matchMedia("(max-width: 767px)").matches ? 'bottom' : 'auto'
    };

    shareButtons.forEach(function (button) {
      var buttonOptions = Object.assign({}, options, {
        content: getShareContent(button)
      });
      new bootstrap.Popover(button, buttonOptions);
      button.addEventListener('show.bs.popover', function () {
        hideProductSharePopovers(button);
      });
    });

    document.addEventListener('click', function (event) {
      if (event.target.closest('.product_share') || event.target.closest('.product-share-popover')) return;
      hideProductSharePopovers();
    });

    document.addEventListener('keyup', function (event) {
      if (event.code === 'Escape') hideProductSharePopovers();
    });

    window.CB_HIDE_PRODUCT_SHARE_POPOVERS = hideProductSharePopovers;
});
}

if (window.matchMedia("(min-width: 992px)").matches) {
  document.querySelectorAll(".gallery_main_card").forEach(container => {
    const bgUrl = container.getAttribute("data-bg");
    if (bgUrl) {
      container.style.backgroundImage = `url(${bgUrl})`;
      container.style.backgroundSize = "contain";
      container.style.backgroundPosition = "center";
      container.style.transition = "background-position 0.6s ease-out, background-size 0.6s ease-out";
    }

    let animationFrame;

    const onMouseMove = (e) => {
      if (animationFrame) cancelAnimationFrame(animationFrame);
      animationFrame = requestAnimationFrame(() => {
        const { left, top, width, height } = container.getBoundingClientRect();
        const x = ((e.clientX - left) / width) * 100;
        const y = ((e.clientY - top) / height) * 100;

        container.style.backgroundPosition = `${x}% ${y}%`;
      });
    };

    const onMouseEnter = () => {
      container.style.transition = "background-position 0.4s ease-out, background-size 0.6s ease";
      container.style.backgroundSize = "150%";
    };

    const onMouseLeave = () => {
      container.style.transition = "background-position 0.6s ease, background-size 0.8s ease";
      container.style.backgroundSize = "contain";
      container.style.backgroundPosition = "center";
    };

    container.addEventListener("mouseenter", onMouseEnter);
    container.addEventListener("mousemove", onMouseMove);
    container.addEventListener("mouseleave", onMouseLeave);
  });
}

{% endjavascript %}
<script>
  window.productData = {
    pricePerSqm: {{ product_price_per_sqm | default: 0 | json }},
    sqmPerBox: {{ product_sqm_per_box | default: 0 | json }},
    selectedVariantSqmPerBox: {{ selected_tile_sqm_per_box_number | default: 0 | json }}
  };
</script>
<script>
  (function () {
    function onReady(callback) {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", callback);
      } else {
        callback();
      }
    }

    function parseNumber(value) {
      if (value === null || value === undefined || value === "") return 0;
      return parseFloat(String(value).replace(/[^0-9.-]/g, "")) || 0;
    }

    function formatNumber(value) {
      var number = Number(value);
      if (!Number.isFinite(number)) return "0";
      return Number.isInteger(number) ? String(number) : number.toFixed(2);
    }

    function formatMoney(value) {
      var number = Number(value);
      if (!Number.isFinite(number)) return "$0.00";
      return "$" + number.toFixed(2);
    }

    function initTileCalculator() {
      var root = document.querySelector(".main_product_information_wrapper");
      if (!root) return;

      var productData = window.productData || {};
      var areaInput = root.querySelector("#area-input");
      var addToCartBtn = root.querySelector("#add-to-cart");
      var variantSelect = root.querySelector("#ProductSelect-product-template");
      var calcBtn = root.querySelector(".tile_calculation_areas_cta .calculate_btn");
      var areaKnownBtn = root.querySelector("#area-known");
      var areaCalculateBtn = root.querySelector("#area-to-calculate");
      var squareMetreBlock = root.querySelector(".your_square_metre");
      var calculateSquareBlock = root.querySelector(".calculate_square_metre");
      var optionCards = root.querySelectorAll(".area_options_block_card");
      var calculatorError = root.querySelector("#tile-calculator-error");
      var roomCalculatorError = root.querySelector("#tile-room-calculator-error");
      var qtyWrapper = root.querySelector("#tile-qty-wrapper");
      var qtyInput = qtyWrapper ? qtyWrapper.querySelector("input.quantity__input") : null;
      var MAX_CALCULATOR_SQM = 99999;
      var MAX_CALCULATOR_SQM_MESSAGE = "Please enter a smaller square metre value.";
      var KNOWN_VALIDATION_MESSAGE = "Please enter a valid measurement.";
      var ROOM_VALIDATION_MESSAGE = "Please enter a valid measurement.";
      var ROOM_MAX_MESSAGE = "Please enter a smaller measurement.";

      if (!areaInput) return;

      var knownTargets = {
        needed: root.querySelector("#total-option-area-known"),
        included: root.querySelector("#final-total-option-area-known"),
        boxes: root.querySelector("#total-box-option-area-known"),
        price: root.querySelector("#total-price-option-area-known")
      };
      var calcTargets = {
        needed: root.querySelector("#total-option-area-calc"),
        included: root.querySelector("#final-total-option-area-calc"),
        boxes: root.querySelector("#total-box-option-area-calc"),
        price: root.querySelector("#total-price-option-area-calc")
      };
      var wastageRadios = root.querySelectorAll("input[name='wastage']");
      var wastageCalcRadios = root.querySelectorAll("input[name='wastage_calc']");
      var wastagePercentText = root.querySelectorAll(".wastage_percent");

      function getSelectedOption() {
        if (!variantSelect || variantSelect.selectedIndex < 0) return null;
        return variantSelect.options[variantSelect.selectedIndex] || null;
      }

      function getSqmPerBox() {
        var selectedOption = getSelectedOption();
        var variantSqm = parseNumber(selectedOption && selectedOption.dataset.variantSqmBox);
        var productSqm = parseNumber(productData.sqmPerBox);
        if (!selectedOption) {
          var selectedVariantSqm = parseNumber(productData.selectedVariantSqmPerBox);
          return selectedVariantSqm > 0 ? selectedVariantSqm : productSqm;
        }
        return variantSqm > 0 ? variantSqm : productSqm;
      }

      function getVariantPrice() {
        var selectedOption = getSelectedOption();
        var optionPrice = parseNumber(selectedOption && selectedOption.dataset.price);
        var buttonPrice = parseNumber(addToCartBtn && addToCartBtn.dataset.price);
        return optionPrice > 0 ? optionPrice : buttonPrice;
      }

      function setCalculatorError(message) {
        if (!calculatorError) return;
        calculatorError.textContent = message || "";
        calculatorError.classList.toggle("d-none", !message);
      }

      function setRoomCalculatorError(message) {
        if (!roomCalculatorError) return;
        roomCalculatorError.textContent = message || "";
        roomCalculatorError.classList.toggle("d-none", !message);
      }

      function escapeHtml(value) {
        var map = {
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#039;"
        };
        return String(value || "").replace(/[&<>"']/g, function (char) {
          return map[char];
        });
      }

      function cleanDecimalValue(value) {
        var clean = String(value || "").replace(/,/g, ".").replace(/[^0-9.]/g, "");
        var firstDotIndex = clean.indexOf(".");
        if (firstDotIndex !== -1) {
          clean = clean.slice(0, firstDotIndex + 1) + clean.slice(firstDotIndex + 1).replace(/\./g, "");
        }
        return clean;
      }

      function sanitizeDecimalInput(input) {
        if (!input) return false;
        var original = input.value;
        var clean = cleanDecimalValue(original);
        if (clean !== original) {
          input.value = clean;
          return true;
        }
        return false;
      }

      function parseDecimalInput(input) {
        if (!input) return { value: 0, invalid: false };
        var raw = String(input.value || "").trim();
        if (raw === "") return { value: 0, invalid: false };
        if (raw === "." || !/^\d+(?:\.\d*)?$/.test(raw)) {
          return { value: 0, invalid: true };
        }

        var number = parseFloat(raw);
        if (!Number.isFinite(number) || number < 0) {
          return { value: 0, invalid: true };
        }

        return { value: number, invalid: false };
      }

      function allowDecimalKey(event) {
        if (event.ctrlKey || event.metaKey || event.altKey) return true;
        var allowedKeys = ["Backspace", "Delete", "Tab", "Escape", "Enter", "ArrowLeft", "ArrowRight", "ArrowUp", "ArrowDown", "Home", "End"];
        if (allowedKeys.indexOf(event.key) !== -1) return true;
        if (/^\d$/.test(event.key)) return true;
        if (event.key === "." && event.target.value.indexOf(".") === -1) return true;
        return false;
      }

      function getVariantDisplayTitle(selectedOption) {
        var titleNode = root.querySelector(".js-tile-product-title");
        var productTitle = titleNode && titleNode.dataset.productTitle ? titleNode.dataset.productTitle : document.title;
        var variantTitle = selectedOption && (selectedOption.dataset.title || selectedOption.dataset.value) ? (selectedOption.dataset.title || selectedOption.dataset.value) : "";

        if (!variantTitle || variantTitle === "Default Title") return productTitle;
        return productTitle + " - " + variantTitle;
      }

      function updateVariantTitle(selectedOption) {
        var displayTitle = getVariantDisplayTitle(selectedOption);
        root.querySelectorAll(".js-tile-product-title").forEach(function (titleNode) {
          titleNode.textContent = displayTitle;
        });
      }

      function updateVariantUrl(selectedOption) {
        if (!selectedOption || !selectedOption.dataset.url || !window.history || !window.history.replaceState) return;
        window.history.replaceState({}, "", selectedOption.dataset.url);
      }

      function setAddToCartReady(isReady, boxes) {
        var cleanBoxes = parseInt(boxes, 10) || 0;
        if (addToCartBtn) addToCartBtn.style.display = isReady ? "inline-block" : "none";
        if (qtyWrapper) qtyWrapper.style.display = "none";
        if (qtyInput) qtyInput.value = isReady ? Math.max(1, cleanBoxes) : 1;
      }

      function setResult(targets, result) {
        if (!targets) return;
        if (targets.needed) targets.needed.textContent = formatNumber(result.area);
        if (targets.included) targets.included.textContent = formatNumber(result.finalSqm);
        if (targets.boxes) targets.boxes.textContent = result.boxes ? String(result.boxes) : "0";
        if (targets.price) targets.price.textContent = formatMoney(result.price);
      }

      function blankResult(area) {
        return { area: area || 0, finalSqm: 0, boxes: 0, price: 0, valid: false };
      }

      function doCalculation(area, wastage) {
        var cleanArea = parseNumber(area);
        var cleanWastage = parseNumber(wastage);
        if (cleanArea <= 0) return blankResult(0);

        if (cleanArea > MAX_CALCULATOR_SQM) {
          var tooLarge = blankResult(0);
          tooLarge.error = MAX_CALCULATOR_SQM_MESSAGE;
          return tooLarge;
        }

        var sqmPerBox = getSqmPerBox();
        if (sqmPerBox <= 0) {
          var missingSqm = blankResult(cleanArea);
          missingSqm.error = "SQM per box is missing for this tile. Please set the product or variant SQM per box before using the calculator.";
          return missingSqm;
        }

        var variantPrice = getVariantPrice();
        if (variantPrice <= 0) {
          var missingPrice = blankResult(cleanArea);
          missingPrice.error = "The selected tile price is not available, so the total price cannot be calculated.";
          return missingPrice;
        }

        var totalWithWastage = cleanArea * (1 + cleanWastage / 100);
        var boxes = Math.ceil(totalWithWastage / sqmPerBox);
        var finalSqm = boxes * sqmPerBox;
        var price = boxes * variantPrice;

        return { area: cleanArea, finalSqm: finalSqm, boxes: boxes, price: price, valid: boxes > 0 };
      }

      function setActiveWastage(radios) {
        radios.forEach(function (radio) {
          var card = radio.closest(".wastage_card");
          if (card) card.classList.toggle("active", radio.checked);
        });
      }

      function updateWastageNote(type, value) {
        root.querySelectorAll(".wastage_note").forEach(function (note) {
          note.classList.add("d-none");
        });
        if (parseNumber(value) !== 0) return;

        var selector = type === "known" ? ".your_square_metre .wastage_note" : ".calculate_square_metre .wastage_note";
        var note = root.querySelector(selector);
        if (note) note.classList.remove("d-none");
      }

      function formatWastageLabel(value) {
        return parseNumber(value) === 0 ? "No Wastage" : parseNumber(value) + "%";
      }

      function updateCustomPrices(syncUrl) {
        var selectedOption = getSelectedOption();
        if (selectedOption) {
          if (addToCartBtn) {
            addToCartBtn.dataset.id = selectedOption.value;
            addToCartBtn.dataset.price = selectedOption.dataset.price || "";
            addToCartBtn.dataset.sale = selectedOption.dataset.sale || "";
            addToCartBtn.dataset.sku = selectedOption.dataset.sku || "";
          }
          updateVariantTitle(selectedOption);
          if (syncUrl) updateVariantUrl(selectedOption);

          var skuElement = root.querySelector("#variant-sku");
          if (skuElement) skuElement.textContent = selectedOption.dataset.sku || "";
        }

        var variantPrice = getVariantPrice();
        var sqmPerBox = getSqmPerBox();
        var priceBoxEl = root.querySelector("#price-per-box");
        var priceSqmEl = root.querySelector("#price-per-sqm");

        if (priceBoxEl) {
          priceBoxEl.innerHTML = formatMoney(variantPrice) + " <span>per box</span>";
        }
        if (priceSqmEl) {
          priceSqmEl.innerHTML = sqmPerBox > 0
            ? formatMoney(variantPrice / sqmPerBox) + " <span>per sqm</span>"
            : "<span>per sqm unavailable</span>";
        }
      }

      function syncVisibleOptionsFromVariant() {
        var selectedOption = getSelectedOption();
        if (!selectedOption || !selectedOption.dataset.value) return;

        var selectedValues = selectedOption.dataset.value.split(" / ");
        root.querySelectorAll(".variant-select").forEach(function (select, index) {
          if (selectedValues[index] && select.value !== selectedValues[index]) {
            select.value = selectedValues[index];
          }
        });
      }

      function updateDeleteButtons() {
        root.querySelectorAll(".tile_calculation_area_card").forEach(function (card, index) {
          var button = card.querySelector(".delete_area_calculator");
          if (button) button.style.display = index === 0 ? "none" : "block";
        });
      }

      function calculateMultiArea() {
        var totalArea = 0;
        var valid = false;
        var summaryRows = [];
        var hasInvalidMeasurement = false;
        var hasTooLargeMeasurement = false;

        root.querySelectorAll(".tile_calculation_area_card").forEach(function (card) {
          var lengthInput = card.querySelector(".length_holder input");
          var widthInput = card.querySelector(".width_holder input");
          var lengthResult = parseDecimalInput(lengthInput);
          var widthResult = parseDecimalInput(widthInput);
          var length = lengthResult.value;
          var width = widthResult.value;
          var roomNameInput = card.querySelector(".area_holder input");
          var roomName = roomNameInput && roomNameInput.value.trim() ? roomNameInput.value.trim() : "Area";
          var area = length * width;
          var output = card.querySelector(".tile_area_output");

          if (lengthResult.invalid || widthResult.invalid) {
            hasInvalidMeasurement = true;
            area = 0;
          }

          if (area > MAX_CALCULATOR_SQM) {
            hasTooLargeMeasurement = true;
            area = 0;
          }

          if (!hasInvalidMeasurement && !hasTooLargeMeasurement && length > 0 && width > 0) valid = true;
          totalArea += area;
          if (output) output.textContent = formatNumber(area);

          if (area > 0) {
            summaryRows.push(
              '<div class="calc-summary-row d-flex justify-content-between align-items-center py-1 border-bottom">' +
                '<span class="text-muted text-break">' + escapeHtml(roomName) + '</span>' +
                '<span>' + formatNumber(length) + 'm &times; ' + formatNumber(width) + 'm = <strong>' + formatNumber(area) + ' sqm</strong></span>' +
              '</div>'
            );
          }
        });

        if (hasInvalidMeasurement) {
          setRoomCalculatorError(ROOM_VALIDATION_MESSAGE);
          if (calcBtn) calcBtn.disabled = true;
          return 0;
        }

        if (hasTooLargeMeasurement || totalArea > MAX_CALCULATOR_SQM) {
          setRoomCalculatorError(ROOM_MAX_MESSAGE);
          if (calcBtn) calcBtn.disabled = true;
          return 0;
        }

        setRoomCalculatorError("");

        var summaryEl = root.querySelector("#show-calculation-summary");
        if (summaryEl) {
          summaryEl.innerHTML = summaryRows.length
            ? '<div class="calc-summary-block bg-white rounded p-3 mb-3">' +
                '<p class="fw-bold mb-2">Area Breakdown</p>' +
                summaryRows.join("") +
                '<div class="d-flex justify-content-between align-items-center pt-2 mt-1">' +
                  '<strong>Total</strong>' +
                  '<strong>' + formatNumber(totalArea) + ' sqm</strong>' +
                '</div>' +
              '</div>'
            : "";
        }

        if (calcBtn) calcBtn.disabled = !valid;
        return totalArea;
      }

      function calculateKnown() {
        updateCustomPrices();
        var areaResult = parseDecimalInput(areaInput);
        var wastageInput = root.querySelector("input[name='wastage']:checked");
        var wastage = parseNumber(wastageInput && wastageInput.value);
        if (areaResult.invalid) {
          setResult(knownTargets, blankResult(0));
          wastagePercentText.forEach(function (el) { el.textContent = formatWastageLabel(wastage); });
          updateWastageNote("known", wastage);
          setCalculatorError(KNOWN_VALIDATION_MESSAGE);
          setAddToCartReady(false, 0);
          return;
        }
        var area = areaResult.value;
        var result = doCalculation(area, wastage);

        setResult(knownTargets, result);
        wastagePercentText.forEach(function (el) { el.textContent = formatWastageLabel(wastage); });
        updateWastageNote("known", wastage);
        setCalculatorError(result.error || "");
        setAddToCartReady(result.valid, result.boxes);
      }

      function calculateCalc() {
        updateCustomPrices();
        var area = calculateMultiArea();
        var wastageInput = root.querySelector("input[name='wastage_calc']:checked");
        var wastage = parseNumber(wastageInput && wastageInput.value);
        var result = doCalculation(area, wastage);

        setResult(calcTargets, result);
        wastagePercentText.forEach(function (el) { el.textContent = formatWastageLabel(wastage); });
        updateWastageNote("calc", wastage);
        setCalculatorError(result.error || "");
        setAddToCartReady(result.valid, result.boxes);
      }

      function resetKnown() {
        areaInput.value = "";
        setResult(knownTargets, blankResult(0));
        wastageRadios.forEach(function (radio) { radio.checked = radio.value === "15"; });
        setActiveWastage(wastageRadios);
        wastagePercentText.forEach(function (el) { el.textContent = formatWastageLabel(15); });
        updateWastageNote("known", 15);
        setCalculatorError("");
        setAddToCartReady(false, 0);
      }

      function resetCalc() {
        root.querySelectorAll(".tile_calculation_area_card").forEach(function (card, index) {
          if (index > 0) {
            card.remove();
            return;
          }
          card.querySelectorAll("input").forEach(function (input) { input.value = ""; });
          var output = card.querySelector(".tile_area_output");
          if (output) output.textContent = "0";
        });

        var summaryEl = root.querySelector("#show-calculation-summary");
        if (summaryEl) summaryEl.innerHTML = "";
        setResult(calcTargets, blankResult(0));
        wastageCalcRadios.forEach(function (radio) { radio.checked = radio.value === "15"; });
        setActiveWastage(wastageCalcRadios);
        wastagePercentText.forEach(function (el) { el.textContent = formatWastageLabel(15); });
        updateWastageNote("calc", 15);
        updateDeleteButtons();
        if (calcBtn) calcBtn.disabled = true;
        setRoomCalculatorError("");
        setCalculatorError("");
        setAddToCartReady(false, 0);
      }

      function scrollToResults(selector) {
        var element = root.querySelector(selector);
        if (!element) return;
        window.scrollTo({
          top: element.getBoundingClientRect().top + window.scrollY - 10,
          behavior: "smooth"
        });
      }

      function addRoom() {
        var container = root.querySelector(".tile_calculation_areas");
        var firstCard = root.querySelector(".tile_calculation_area_card");
        var cta = root.querySelector(".tile_calculation_areas_cta");
        if (!container || !firstCard || !cta) return;

        var clone = firstCard.cloneNode(true);
        clone.classList.add("new_area");
        clone.querySelectorAll("input").forEach(function (input) { input.value = ""; });
        var output = clone.querySelector(".tile_area_output");
        if (output) output.textContent = "0";

        container.insertBefore(clone, cta);
        updateDeleteButtons();
        if (calculateMultiArea() > 0) {
          calculateCalc();
        } else {
          setAddToCartReady(false, 0);
        }
      }

      function deleteRoom(target) {
        var cards = root.querySelectorAll(".tile_calculation_area_card");
        if (cards.length <= 1) return;

        var card = target.closest(".tile_calculation_area_card");
        if (!card) return;

        card.remove();
        updateDeleteButtons();
        calculateMultiArea();
        calculateCalc();
      }

      if (areaKnownBtn) {
        areaKnownBtn.addEventListener("click", function () {
          if (squareMetreBlock) squareMetreBlock.classList.remove("d-none");
          if (calculateSquareBlock) calculateSquareBlock.classList.add("d-none");
          optionCards.forEach(function (card) { card.classList.remove("active"); });
          var activeCard = this.closest(".area_options_block_card");
          if (activeCard) activeCard.classList.add("active");
          resetCalc();
          scrollToResults("#input-area");
        });
      }

      if (areaCalculateBtn) {
        areaCalculateBtn.addEventListener("click", function () {
          if (calculateSquareBlock) calculateSquareBlock.classList.remove("d-none");
          if (squareMetreBlock) squareMetreBlock.classList.add("d-none");
          optionCards.forEach(function (card) { card.classList.remove("active"); });
          var activeCard = this.closest(".area_options_block_card");
          if (activeCard) activeCard.classList.add("active");
          resetKnown();
          scrollToResults("#calculate-area");
        });
      }

      root.querySelectorAll(".wastage_card").forEach(function (card) {
        card.addEventListener("click", function () {
          var radio = card.querySelector("input[type='radio']");
          if (!radio || radio.disabled) return;
          radio.checked = true;

          var groupRadios = root.querySelectorAll('input[name="' + radio.name + '"]');
          setActiveWastage(groupRadios);

          if (radio.name === "wastage") calculateKnown();
          if (radio.name === "wastage_calc") calculateCalc();
        });
      });

      wastageRadios.forEach(function (radio) { radio.addEventListener("change", calculateKnown); });
      wastageCalcRadios.forEach(function (radio) { radio.addEventListener("change", calculateCalc); });
      areaInput.addEventListener("input", function () {
        var hadInvalidCharacters = sanitizeDecimalInput(areaInput);
        if (hadInvalidCharacters) {
          setCalculatorError(KNOWN_VALIDATION_MESSAGE);
          setResult(knownTargets, blankResult(0));
          setAddToCartReady(false, 0);
          return;
        }
        calculateKnown();
      });

      if (variantSelect) {
        variantSelect.addEventListener("change", function () {
          updateCustomPrices(true);
          if (parseDecimalInput(areaInput).value > 0) calculateKnown();
          if (calculateMultiArea() > 0) calculateCalc();
        });
      }

      areaInput.addEventListener("keydown", function (event) {
        if (allowDecimalKey(event)) return;
        event.preventDefault();
        setCalculatorError(KNOWN_VALIDATION_MESSAGE);
      });

      root.addEventListener("input", function (event) {
        if (!event.target.closest(".tile_calculation_area_card")) return;
        var hadInvalidCharacters = false;

        if (event.target.classList.contains("tile-measurement-input")) {
          hadInvalidCharacters = sanitizeDecimalInput(event.target);
        }

        if (event.target.classList.contains("tile-area-name-input") && event.target.value.length > 40) {
          event.target.value = event.target.value.slice(0, 40);
        }

        var area = calculateMultiArea();
        if (hadInvalidCharacters) {
          setRoomCalculatorError(ROOM_VALIDATION_MESSAGE);
          setResult(calcTargets, blankResult(0));
          setAddToCartReady(false, 0);
          return;
        }

        if (area > 0) {
          calculateCalc();
        } else {
          setResult(calcTargets, blankResult(0));
          setAddToCartReady(false, 0);
        }
      });

      root.addEventListener("keydown", function (event) {
        if (!event.target.classList || !event.target.classList.contains("tile-measurement-input")) return;
        if (allowDecimalKey(event)) return;
        event.preventDefault();
        setRoomCalculatorError(ROOM_VALIDATION_MESSAGE);
      });

      root.addEventListener("click", function (event) {
        if (event.target.closest(".add_new_area_calculator")) {
          addRoom();
          return;
        }
        if (event.target.closest(".delete_area_calculator")) {
          deleteRoom(event.target);
        }
      });

      if (calcBtn) calcBtn.addEventListener("click", calculateCalc);

      syncVisibleOptionsFromVariant();
      updateCustomPrices();
      resetKnown();
      resetCalc();
    }

    onReady(initTileCalculator);
  })();
</script>
