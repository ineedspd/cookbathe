                                                    <a href="{{ block.settings.image-3-link }}" class="brand_card">
                                                      <img
                                                        src="{{ block.settings.image-3 | img_url:'master'}}"
                                                        alt="{{ block.settings.image-3.alt }}" loading="lazy"
                                                      >
                                                    </a>
                                                  {% endif %}
                                                  {% if block.settings['image-4'].size != blank %}
