                        <span class="smt_icon">   {%- render 'icon-toggle' %}
                        {% render 'icon-down-arrow' -%}</span>
                      
                      <span>{{- link.title -}}</span>
                        
                      </a>

                      {%- if link.title == 'Brands' -%}
                        <div class="mega_menu">
                          <div class="mega_menu_inner">
                            <div class="container">
                              {%- if link.title != 'Brands' -%}
