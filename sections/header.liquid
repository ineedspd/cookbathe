                                  <div class="mega_menu_left_block">
                                    <p class="h2">{{ link.title }}</p>
                                    <ul class="sub_menu list-unstyled">
                                      {%- for childlink in link.links -%}
                                        <li
                                          class="sub_menu_item"
                                          data-name="{{ childlink.title }}"
                                          data-target="{{ childlink.title | handle }}-submenu"
                                        >
                                          <a href="{{ childlink.url }}">
                                            {{- childlink.title }}
                                            {% render 'icon-right-arrow', classses: 'd-none d-lg-block' -%}
                                          </a>
                                          {% render 'icon-plus', classses: 'd-lg-none' -%}
                                        </li>
                                      {% endfor %}
                                    </ul>
                                  </div>

                                  {%- if link.links.size > 0 and issub -%}
                                    <div class="mega_menu_right_block d-flex flex-column {{ link.links.size }}--size">
                                      {%- for childlink in link.links -%}
                                        <div
                                          class="sub_menu_child {{ childlink.title | handle }}-sub"
                                          id="{{ childlink.title | handle }}-submenu"
                                        >
                                          <div class="sub_menu_child_inner submenu_style_one d-flex">
                                            <div class="style_one_left_block">
                                              <div class="room_one_listing">
                                                <p class="h3">{{ childlink.title }}</p>
                                                <ul class="list-unstyled">
                                                  {%- for subchildlink in childlink.links -%}
                                                    <li
                                                      data-name="{{ subchildlink.title }}"
                                                      room-data-target="{{ subchildlink.title | handle }}"
                                                    >
                                                      <a
                                                        href="{{ subchildlink.url }}"
                                                        room-data-target="{{ subchildlink.title | handle }}"
                                                      >
                                                        {{ subchildlink.title | escape }}
                                                      </a>
                                                      {% comment %}
                                                        {% render 'icon-plus', classses: 'd-lg-none' -%}
                                                      {% endcomment %}
                                                    </li>
                                                  {%- endfor -%}
                                                </ul>
                                              </div>
                                             <div
