                                                        src="{{ block.settings.image-4 | img_url:'master'}}"
                                                        alt="{{ block.settings.image-4.alt }}" loading="lazy"
                                                      >
                                                    </a>
                                                  {% endif %}
                                                </div>
                                              </div>
                                            </div>
                                          </div>
                                      {% endcase %}
                                    {% endfor %}
                                  </div>
                                </div>
                              {%- endif -%}
                            </div>
                          </div>
                        </div>
                      {%- else -%}
                        <div class="single_submenu mega_menu">
                          <div class="mega_menu_inner">
                            <div class="mega_menu_content d-flex position-relative pt-0 p-lg-0 w-100">
                              <ul class="sub_menu list-unstyled w-100">
                              {%- for childlink in link.links -%}
                                <li class="sub_menu_item">
                                  <a
                                    class="{% if childlink.current %} nav_link_active{% endif %}"
                                    href="{{ childlink.url }}"
                                  >
                                    {{- childlink.title | escape -}}
                                     {%- if childlink.links.size > 0 %}
                                      {% render 'icon-right-arrow', classses: 'd-none d-lg-block' -%}
                                     {%- endif -%}
                                  </a>
                                    {%- if childlink.links.size > 0 %}
                                  
                                  {% render 'icon-plus', classses: 'd-lg-none' -%}
                                    {%- endif -%}
                                   {%- if childlink.links.size > 0 %}
                                    <ul class="sub_sub_menu list-unstyled">
                              {%- for childlink_childlink in childlink.links -%}
                                <li class="sub_menu_item">
                                  <a
                                    class="{% if childlink_childlink.current %} nav_link_active{% endif %}"
                                    href="{{ childlink_childlink.url }}"
                                  >
                                    {{- childlink_childlink.title | escape -}}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                                      {%- endif -%}
                                </li>
                              {%- endfor -%}
                            </ul>
                            </div>
                          </div>
                        </div>
                      {%- endif -%}
                    </li>
                  {% else %}
                    <li class="nav-item">
                      <a
                        class="nav-link submenu-toggle{% if link.current %} nav_link_active{% endif %}"
                        href="{{ link.url }}"
                      >
                          <span class="empt_link"> </span>
                        <span>{{ link.title | escape }} </span>
                      </a>
                    </li>
                  {% endif %}
                {%- endfor -%}
              {% endif %}

              {% if section.settings['btn-name'] != blank %}
                <li class="nav-item">
                  <a class="nav-link btn btn-outline-primary" href="{{ section.settings.btn-link }}">
                    {{- section.settings['btn-name'] -}}
                  </a>
                </li>
              {% endif %}
            </ul>
            <div class="mobile_menu_cta d-flex align-items-center d-lg-none">
              <a href="/pages/contact" class="btn btn-outline-primary">{% render 'icon-contact' %} Contact Us</a>
              <a href="/account" class="btn btn-outline-primary">
                {%- render 'icon-account' %}
                {% if customer %} Hi, {{ customer.first_name }} {% else %}My Account{% endif -%}
              </a>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  </nav>
</div>
