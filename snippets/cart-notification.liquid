{% comment %}
  Renders cart notification

  Accepts:
  - color_scheme: {String} sets the color scheme of the notification (optional)

  Usage:
  {% render 'cart-notification' %}
{% endcomment %}

<cart-notification>
  <div class="cart-notification-wrapper container">
    <div
      id="cart-notification"
      class="cart-notification {% if cart.items.size == 0 %}cart-notification-empty{% endif %} focus-inset{% if color_scheme %} color-{{ color_scheme }} gradient{% endif %}"
      aria-modal="true"
      aria-label="{{ 'general.cart.item_added' | t }}"
      role="dialog"
      tabindex="-1"
    >
      <div class="cart-notification__header d-block">
        {% comment %}
        <h2 class="cart-notification__heading caption-large text-body">
          {%- render 'icon-checkmark' -%}
          {{ 'general.cart.item_added' | t }}
        </h2>
        {% endcomment %}
        {% if cart.items.size == 0 %}
          <p class="text-center">Your cart is empty</p>
        {% endif %} 
        {% comment %}
         <button
          type="button"
          class="cart-notification__close modal__close-button link link--text focus-inset"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
         {% endcomment %}
        <div class="d-flex flex-column">
          {%- for item in cart.items -%}
            <div class="card flex-row">
              <div class="cart_card_img">
               <a href="{{ item.url }}"><img src="{{ item.image | img_url:'master'}}" alt="{{ item.product.title | strip_html | escape }}">
              </a>
              </div>
              <div class="cart_card_content">
                <a href="{{ item.url }}">{{ item.product.title | escape }}</a>
                <div class="cart_card_content_inner d-flex align-items-center justify-content-between">
                            
              {%- if item.product.has_only_default_variant == false
                or item.properties.size != 0
                or item.selling_plan_allocation != null
              -%}
                <dl>
                  {%- if item.product.has_only_default_variant == false -%}
                    {%- for option in item.options_with_values -%}
                      <div class="product-option">
                        <dt>{{ option.name }}:</dt>
                        <dd>{{ option.value }}</dd>
                      </div>
                    {%- endfor -%}
                  {%- endif -%}

                  {% comment %}
                  {%- for property in item.properties -%}
                    {%- assign property_first_char = property.first | slice: 0 -%}
                    {%- if property.last != blank and property_first_char != '_' -%}
                      <div class="product-option">
                        <dt>{{ property.first }}:</dt>
                        <dd>
                          {%- if property.last contains '/uploads/' -%}
                            <a href="{{ property.last }}" class="link" target="_blank">
                              {{ property.last | split: '/' | last }}
                            </a>
                          {%- else -%}
                            {{ property.last }}
                          {%- endif -%}
                        </dd>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                  {% endcomment %}
                </dl>
              {% endif %}
             <p class="cart_card_price mb-0">{{ item.original_price | times:1 | money }}</p>     
              <div class="cart_products_qty d-flex">
                {%- if item.product.template_suffix == 'tile' -%}
                  <input
                    type="number"
                    class="form-control cart-qty-input"
                    data-line="{{ forloop.index }}"
                    aria-label="Quantity"
                    data-id="{{ item.id }}"
                    value="{{ item.quantity }}"
                    min="1"
                    style="width:80px;"
                  >
                {%- else -%}
                  {%- assign qty_limit = item.quantity | at_least: 10 -%}
                  <select class="form-select cart-qty-select" aria-label="Quantity" data-id="{{ item.id }}" data-line="{{ forloop.index }}">
                    {%- for i in (1..qty_limit) -%}
                      <option value="{{ i }}" {% if i == item.quantity %}selected{% endif %}>{{ i }}</option>
                    {%- endfor -%}
                  </select>
                {%- endif -%}
              </div>
                  <a href="{{ item.url_to_remove }}" class="remove_product">{% render 'icon-close' %}</a>
                </div>
              </div>
           
    
            </div>  
          {% endfor %}
        </div>       
      </div>
      <div id="cart-notification-product" class="cart-notification-product"></div>
      <div class="cart-notification__links">
        <a
          href="{{ routes.cart_url }}"
          id="cart-notification-button"
          class="btn-checkout btn btn-primary w-100"
        ></a>
        {% if cart.items.size != 0 %}
         <div class="subtotal-cart d-flex align-items-center justify-content-between">
           <label>Subtotal:</label>
           <p class="mb-0">{{ cart.total_price | times:1 | money }}</p>
         </div>
        <!-- Route Code Edited 11/13/2024 -->
        <div
          class="route-div"
          data-payer="no_coverage"
           desktop-align="center"
             data-allow-multiple-renders
        ></div>
        <style>
        	route-protect-widget:not([payer='no_coverage']) .pw-container::after {
        	content: "*Enjoy extra peace of mind with optional shipping protection – covering you against loss, theft, or damage in transit.";
        	white-space: pre-wrap;
        	display: inline-block;
        	text-align: center;
        	font-size: 12px !important;
        	}
        </style> 
        <!-- End Route Code --> 
        <form action="{{ routes.cart_url }}" method="post" id="cart-notification-form">
          <button class="btn-checkout btn btn-primary w-100" name="checkout">{% render 'icon-check' %} Go To Checkout</button>
        </form>
        {% else %}  
        <a href="/collections/all" class="btn btn-primary">
          {{- 'general.continue_shopping' | t -}}
        </a>
        {% endif %}  
      </div>
    </div>
  </div>
</cart-notification>
{% style %}
  .cart-notification {
     display: none;
  }
{% endstyle %}
