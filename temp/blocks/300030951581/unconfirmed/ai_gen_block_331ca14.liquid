{% doc %}
  @prompt
    add contact form, and insert these fields email,firstname,lastname,phonenumber, message. all fields need seperate rows, add placeholders for all , left align labels for all
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__heading-{{ ai_gen_id }} {
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    text-align: left;
  }

  .ai-contact-form__field-group-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    display: block;
    margin-bottom: 8px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 500;
    text-align: left;
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 16px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    text-align: left;
  }

  .ai-contact-form__input-{{ ai_gen_id }}::placeholder,
  .ai-contact-form__textarea-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
    opacity: 1;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.input_focus_color }};
    outline-offset: 2px;
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    padding: 16px;
    margin-bottom: 16px;
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    text-align: left;
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    padding: 16px;
    margin-bottom: 16px;
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    text-align: left;
  }

  .ai-contact-form__required-{{ ai_gen_id }} {
    color: {{ block.settings.error_text_color }};
  }
{% endstyle %}

<div class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {%- form 'contact' -%}
    {%- if form.posted_successfully? -%}
      <div class="ai-contact-form__success-{{ ai_gen_id }}" id="ai-contact-form-success-{{ ai_gen_id }}">
        {{ block.settings.success_message }}
      </div>
    {%- endif -%}

    {%- if form.errors -%}
      <div class="ai-contact-form__error-{{ ai_gen_id }}" id="ai-contact-form-error-{{ ai_gen_id }}">
        {{ block.settings.error_message }}
      </div>
    {%- endif -%}

    {%- if block.settings.heading != blank -%}
      <h2 class="ai-contact-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {%- endif -%}

    <div class="ai-contact-form__field-group-{{ ai_gen_id }}">
      <label for="ai-contact-email-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
        {{ block.settings.email_label }}
        <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <input
        type="email"
        id="ai-contact-email-{{ ai_gen_id }}"
        name="contact[email]"
        class="ai-contact-form__input-{{ ai_gen_id }}"
        value="{{ form.email }}"
        placeholder="{{ block.settings.email_placeholder }}"
        autocomplete="email"
        required
        aria-required="true"
        {% if form.errors %}
          aria-invalid="true"
          aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
        {% endif %}
      >
    </div>

    <div class="ai-contact-form__field-group-{{ ai_gen_id }}">
      <label for="ai-contact-firstname-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
        {{ block.settings.firstname_label }}
        <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <input
        type="text"
        id="ai-contact-firstname-{{ ai_gen_id }}"
        name="contact[first_name]"
        class="ai-contact-form__input-{{ ai_gen_id }}"
        value="{{ form.first_name }}"
        placeholder="{{ block.settings.firstname_placeholder }}"
        autocomplete="given-name"
        required
        aria-required="true"
      >
    </div>

    <div class="ai-contact-form__field-group-{{ ai_gen_id }}">
      <label for="ai-contact-lastname-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
        {{ block.settings.lastname_label }}
        <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <input
        type="text"
        id="ai-contact-lastname-{{ ai_gen_id }}"
        name="contact[last_name]"
        class="ai-contact-form__input-{{ ai_gen_id }}"
        value="{{ form.last_name }}"
        placeholder="{{ block.settings.lastname_placeholder }}"
        autocomplete="family-name"
        required
        aria-required="true"
      >
    </div>

    <div class="ai-contact-form__field-group-{{ ai_gen_id }}">
      <label for="ai-contact-phone-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
        {{ block.settings.phone_label }}
        <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <input
        type="tel"
        id="ai-contact-phone-{{ ai_gen_id }}"
        name="contact[phone]"
        class="ai-contact-form__input-{{ ai_gen_id }}"
        value="{{ form.phone }}"
        placeholder="{{ block.settings.phone_placeholder }}"
        autocomplete="tel"
        required
        aria-required="true"
      >
    </div>

    <div class="ai-contact-form__field-group-{{ ai_gen_id }}">
      <label for="ai-contact-message-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
        {{ block.settings.message_label }}
        <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <textarea
        id="ai-contact-message-{{ ai_gen_id }}"
        name="contact[body]"
        class="ai-contact-form__textarea-{{ ai_gen_id }}"
        placeholder="{{ block.settings.message_placeholder }}"
        required
        aria-required="true"
      >{{ form.body }}</textarea>
    </div>

    <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
      {{ block.settings.button_text }}
    </button>
  {%- endform -%}
</div>

