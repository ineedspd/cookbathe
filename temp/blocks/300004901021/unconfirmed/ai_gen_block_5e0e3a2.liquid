{% doc %}
  @prompt
    generate contact us form
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-contact-form-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-contact-form-header-{{ ai_gen_id }} {
    margin-bottom: 24px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form-title-{{ ai_gen_id }} {
    margin: 0 0 8px 0;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-contact-form-description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-contact-form-fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-contact-form-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .ai-contact-form-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .ai-contact-form-input-{{ ai_gen_id }},
  .ai-contact-form-textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.input_background_color }};
    transition: border-color 0.2s ease;
  }

  .ai-contact-form-input-{{ ai_gen_id }}:focus,
  .ai-contact-form-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-contact-form-textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
    font-family: inherit;
  }

  .ai-contact-form-button-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s ease;
    width: 100%;
  }

  .ai-contact-form-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form-message-{{ ai_gen_id }} {
    padding: 12px 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    margin-bottom: 16px;
  }

  .ai-contact-form-message-success-{{ ai_gen_id }} {
    background-color: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }

  .ai-contact-form-message-error-{{ ai_gen_id }} {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form-row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-contact-form-container-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-form-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-contact-form-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-contact-form-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <p class="ai-contact-form-description-{{ ai_gen_id }}">{{ block.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <div class="ai-contact-form-message-{{ ai_gen_id }} ai-contact-form-message-success-{{ ai_gen_id }}" id="ai-contact-form-success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="ai-contact-form-message-{{ ai_gen_id }} ai-contact-form-message-error-{{ ai_gen_id }}" id="ai-contact-form-error-{{ ai_gen_id }}">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="ai-contact-form-fields-{{ ai_gen_id }}">
        <div class="ai-contact-form-row-{{ ai_gen_id }}">
          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="ai-contact-name-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
              Name <span aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="ai-contact-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              autocomplete="name"
              required
              aria-required="true"
              {% if form.errors %}
                aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="ai-contact-email-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
              Email <span aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="ai-contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              required
              aria-required="true"
              {% if form.errors %}
                aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>
        </div>

        {% if block.settings.show_phone %}
          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="ai-contact-phone-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
              Phone {% if block.settings.phone_required %}<span aria-hidden="true">*</span>{% endif %}
            </label>
            <input
              type="tel"
              id="ai-contact-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              autocomplete="tel"
              {% if block.settings.phone_required %}required aria-required="true"{% endif %}
            >
          </div>
        {% endif %}

        {% if block.settings.show_subject %}
          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="ai-contact-subject-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
              Subject {% if block.settings.subject_required %}<span aria-hidden="true">*</span>{% endif %}
            </label>
            <input
              type="text"
              id="ai-contact-subject-{{ ai_gen_id }}"
              name="contact[subject]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              {% if block.settings.subject_required %}required aria-required="true"{% endif %}
            >
          </div>
        {% endif %}

        <div class="ai-contact-form-field-{{ ai_gen_id }}">
          <label for="ai-contact-message-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
            Message <span aria-hidden="true">*</span>
          </label>
          <textarea
            id="ai-contact-message-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-contact-form-textarea-{{ ai_gen_id }}"
            required
            aria-required="true"
            {% if form.errors %}
              aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
            {% endif %}
          ></textarea>
        </div>

        <button type="submit" class="ai-contact-form-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>
      </div>
    {% endform %}
  </div>
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        const successMessage = this.querySelector('#ai-contact-form-success-{{ ai_gen_id }}');
        const errorMessage = this.querySelector('#ai-contact-form-error-{{ ai_gen_id }}');

        if (successMessage || errorMessage) {
          const messageElement = successMessage || errorMessage;
          messageElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
          messageElement.focus();
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    {
      "type": "header",
      "content": "Form header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Get in touch"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We'd love to hear from you. Send us a message and we'll respond as soon as possible."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Form fields"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "phone_required",
      "label": "Phone required",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_subject",
      "label": "Show subject field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "subject_required",
      "label": "Subject required",
      "default": false
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Send message"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Button border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Messages"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for contacting us. We'll get back to you as soon as possible."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 800
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Input background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border",
      "default": "#D1D1D1"
    },
    {
      "type": "color",
      "id": "input_focus_border_color",
      "label": "Input focus border",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Input border radius",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Contact form"
    }
  ]
}
{% endschema %}
