{% doc %}
  @prompt
    generate contace us form
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-contact-form__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__field-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    margin-bottom: 8px;
    font-weight: 500;
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    font-size: 14px;
    font-family: inherit;
    box-sizing: border-box;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.input_focus_color }};
    outline-offset: 2px;
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    resize: vertical;
    min-height: 120px;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: 14px 32px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
    transition: background-color 0.3s ease;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
    padding: 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
    text-align: center;
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
    padding: 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__error-list-{{ ai_gen_id }} {
    margin: 0;
    padding-left: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-contact-form__container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-form__container-{{ ai_gen_id }}">
    {%- if block.settings.heading != blank -%}
      <h2 class="ai-contact-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {%- endif -%}

    {%- if block.settings.description != blank -%}
      <div class="ai-contact-form__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {%- endif -%}

    {%- form 'contact' -%}
      {%- if form.posted_successfully? -%}
        <div class="ai-contact-form__success-{{ ai_gen_id }}" id="ai-contact-form-success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="ai-contact-form__error-{{ ai_gen_id }}" id="ai-contact-form-error-{{ ai_gen_id }}">
          <strong>{{ block.settings.error_heading }}</strong>
          <ul class="ai-contact-form__error-list-{{ ai_gen_id }}">
            {%- for field in form.errors -%}
              <li>{{ field | capitalize }} {{ form.errors.messages[field] }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label for="ai-contact-name-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          {{ block.settings.name_label }}
          {%- if block.settings.name_required -%}<span aria-label="required">*</span>{%- endif -%}
        </label>
        <input
          type="text"
          id="ai-contact-name-{{ ai_gen_id }}"
          name="contact[{{ block.settings.name_label }}]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          autocomplete="name"
          {%- if block.settings.name_required -%}required{%- endif -%}
          {%- if form.errors contains 'name' -%}
            aria-invalid="true"
            aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
          {%- endif -%}
        >
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label for="ai-contact-email-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          {{ block.settings.email_label }}<span aria-label="required">*</span>
        </label>
        <input
          type="email"
          id="ai-contact-email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          required
          {%- if form.errors contains 'email' -%}
            aria-invalid="true"
            aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
          {%- endif -%}
        >
      </div>

      {%- if block.settings.show_phone -%}
        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-phone-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.phone_label }}
            {%- if block.settings.phone_required -%}<span aria-label="required">*</span>{%- endif -%}
          </label>
          <input
            type="tel"
            id="ai-contact-phone-{{ ai_gen_id }}"
            name="contact[{{ block.settings.phone_label }}]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            autocomplete="tel"
            {%- if block.settings.phone_required -%}required{%- endif -%}
            {%- if form.errors contains 'phone' -%}
              aria-invalid="true"
              aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
            {%- endif -%}
          >
        </div>
      {%- endif -%}

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label for="ai-contact-message-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          {{ block.settings.message_label }}<span aria-label="required">*</span>
        </label>
        <textarea
          id="ai-contact-message-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-contact-form__textarea-{{ ai_gen_id }}"
          required
          {%- if form.errors contains 'body' -%}
            aria-invalid="true"
            aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
          {%- endif -%}
        ></textarea>
      </div>

      <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    {%- endform -%}
  </div>
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const successMessage = this.querySelector('#ai-contact-form-success-{{ ai_gen_id }}');
        const errorMessage = this.querySelector('#ai-contact-form-error-{{ ai_gen_id }}');

        if (successMessage) {
          successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        if (errorMessage) {
          errorMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Contact form",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
