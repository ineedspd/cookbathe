{% doc %}
  @prompt
    contact us form generate, email is first, and name needs two fields first  name and last name, first last names need two eperate rows, add phone no before the message field, country code needs to be add in as phone no field
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-contact-form__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 500;
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }},
  .ai-contact-form__select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    font-size: 14px;
    font-family: inherit;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus,
  .ai-contact-form__select-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.input_focus_color }};
    outline-offset: 2px;
  }

  .ai-contact-form__phone-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-contact-form__country-code-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 120px;
  }

  .ai-contact-form__phone-input-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    padding: 14px 28px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    width: 100%;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.success_background_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
    text-align: center;
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.error_background_color }};
    color: {{ block.settings.error_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__error-list-{{ ai_gen_id }} {
    margin: 0;
    padding-left: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form__container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-contact-form__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-contact-form__country-code-{{ ai_gen_id }} {
      width: 100px;
    }
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-form__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-contact-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-contact-form__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <div 
          id="ai-contact-form-success-{{ ai_gen_id }}"
          class="ai-contact-form__success-{{ ai_gen_id }}"
        >
          {{ block.settings.success_message }}
        </div>
      {% endif %}

      {% if form.errors %}
        <div 
          id="ai-contact-form-error-{{ ai_gen_id }}"
          class="ai-contact-form__error-{{ ai_gen_id }}"
        >
          <strong>{{ block.settings.error_heading }}</strong>
          <ul class="ai-contact-form__error-list-{{ ai_gen_id }}">
            {% for field in form.errors %}
              <li>{{ field | capitalize }} {{ form.errors.messages[field] }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      <div class="ai-contact-form__fields-{{ ai_gen_id }}">
        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-email-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.email_label }} *
          </label>
          <input
            type="email"
            id="ai-contact-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            value="{% if form.email %}{{ form.email }}{% endif %}"
            placeholder="{{ block.settings.email_placeholder }}"
            required
            autocomplete="email"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
            {% endif %}
            {% if form.posted_successfully? %}
              aria-describedby="ai-contact-form-success-{{ ai_gen_id }}"
            {% endif %}
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-first-name-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.first_name_label }}{% if block.settings.first_name_required %} *{% endif %}
          </label>
          <input
            type="text"
            id="ai-contact-first-name-{{ ai_gen_id }}"
            name="contact[first_name]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            value="{% if form.first_name %}{{ form.first_name }}{% endif %}"
            placeholder="{{ block.settings.first_name_placeholder }}"
            {% if block.settings.first_name_required %}required{% endif %}
            autocomplete="given-name"
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-last-name-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.last_name_label }}{% if block.settings.last_name_required %} *{% endif %}
          </label>
          <input
            type="text"
            id="ai-contact-last-name-{{ ai_gen_id }}"
            name="contact[last_name]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            value="{% if form.last_name %}{{ form.last_name }}{% endif %}"
            placeholder="{{ block.settings.last_name_placeholder }}"
            {% if block.settings.last_name_required %}required{% endif %}
            autocomplete="family-name"
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-phone-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.phone_label }}{% if block.settings.phone_required %} *{% endif %}
          </label>
          <div class="ai-contact-form__phone-wrapper-{{ ai_gen_id }}">
            <select
              id="ai-contact-country-code-{{ ai_gen_id }}"
              name="contact[country_code]"
              class="ai-contact-form__select-{{ ai_gen_id }} ai-contact-form__country-code-{{ ai_gen_id }}"
              {% if block.settings.phone_required %}required{% endif %}
            >
              <option value="+1">+1 (US)</option>
              <option value="+44">+44 (UK)</option>
              <option value="+91">+91 (IN)</option>
              <option value="+61">+61 (AU)</option>
              <option value="+81">+81 (JP)</option>
              <option value="+86">+86 (CN)</option>
              <option value="+33">+33 (FR)</option>
              <option value="+49">+49 (DE)</option>
              <option value="+39">+39 (IT)</option>
              <option value="+34">+34 (ES)</option>
              <option value="+7">+7 (RU)</option>
              <option value="+55">+55 (BR)</option>
              <option value="+52">+52 (MX)</option>
              <option value="+27">+27 (ZA)</option>
              <option value="+82">+82 (KR)</option>
              <option value="+65">+65 (SG)</option>
              <option value="+971">+971 (AE)</option>
              <option value="+966">+966 (SA)</option>
              <option value="+64">+64 (NZ)</option>
              <option value="+31">+31 (NL)</option>
              <option value="+46">+46 (SE)</option>
              <option value="+47">+47 (NO)</option>
              <option value="+45">+45 (DK)</option>
              <option value="+41">+41 (CH)</option>
              <option value="+32">+32 (BE)</option>
              <option value="+43">+43 (AT)</option>
              <option value="+48">+48 (PL)</option>
              <option value="+351">+351 (PT)</option>
              <option value="+353">+353 (IE)</option>
              <option value="+358">+358 (FI)</option>
            </select>
            <input
              type="tel"
              id="ai-contact-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-contact-form__input-{{ ai_gen_id }} ai-contact-form__phone-input-{{ ai_gen_id }}"
              value="{% if form.phone %}{{ form.phone }}{% endif %}"
              placeholder="{{ block.settings.phone_placeholder }}"
              {% if block.settings.phone_required %}required{% endif %}
              autocomplete="tel"
            >
          </div>
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-message-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.message_label }} *
          </label>
          <textarea
            id="ai-contact-message-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-contact-form__textarea-{{ ai_gen_id }}"
            placeholder="{{ block.settings.message_placeholder }}"
            required
          >{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>

        <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>
      </div>
    {% endform %}
  </div>
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        const successMessage = this.querySelector('.ai-contact-form__success-{{ ai_gen_id }}');
        const errorMessage = this.querySelector('.ai-contact-form__error-{{ ai_gen_id }}');

        if (successMessage || errorMessage) {
          const targetElement = successMessage || errorMessage;
          targetElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

