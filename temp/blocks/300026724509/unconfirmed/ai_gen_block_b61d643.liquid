{% doc %}
  @prompt
    contact us form generate, email is first, and name needs two fields first  name and last name, first last names need two eperate rows, add phone no before the message field, country code needs to be add in as phone no field, for country code need flag, add country flag for it country in the phone field
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    font-size: 28px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-contact-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 500;
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }},
  .ai-contact-form__select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form__phone-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-contact-form__country-code-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 120px;
  }

  .ai-contact-form__phone-input-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: 16px;
    padding: 12px;
    background-color: rgba(0, 128, 96, 0.1);
    border-radius: 4px;
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: 8px;
    font-size: 14px;
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {%- form 'contact' -%}
    <div class="ai-contact-form__fields-{{ ai_gen_id }}">
      {%- if block.settings.heading != blank -%}
        <h2 class="ai-contact-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {%- endif -%}

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-contact-form__label-{{ ai_gen_id }}" for="contact-email-{{ ai_gen_id }}">
          {{ block.settings.email_label }}
        </label>
        <input
          type="email"
          id="contact-email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          value="{{ form.email }}"
          autocomplete="email"
          required
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="contact-email-error-{{ ai_gen_id }}"
          {% endif %}
        >
        {%- if form.errors.email -%}
          <div id="contact-email-error-{{ ai_gen_id }}" class="ai-contact-form__error-{{ ai_gen_id }}">
            {{ form.errors.email }}
          </div>
        {%- endif -%}
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-contact-form__label-{{ ai_gen_id }}" for="contact-first-name-{{ ai_gen_id }}">
          {{ block.settings.first_name_label }}
        </label>
        <input
          type="text"
          id="contact-first-name-{{ ai_gen_id }}"
          name="contact[first_name]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          value="{{ form.first_name }}"
          autocomplete="given-name"
        >
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-contact-form__label-{{ ai_gen_id }}" for="contact-last-name-{{ ai_gen_id }}">
          {{ block.settings.last_name_label }}
        </label>
        <input
          type="text"
          id="contact-last-name-{{ ai_gen_id }}"
          name="contact[last_name]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          value="{{ form.last_name }}"
          autocomplete="family-name"
        >
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-contact-form__label-{{ ai_gen_id }}" for="contact-phone-{{ ai_gen_id }}">
          {{ block.settings.phone_label }}
        </label>
        <div class="ai-contact-form__phone-wrapper-{{ ai_gen_id }}">
          <select
            id="contact-country-code-{{ ai_gen_id }}"
            name="contact[country_code]"
            class="ai-contact-form__select-{{ ai_gen_id }} ai-contact-form__country-code-{{ ai_gen_id }}"
          >
            <option value="+1">🇺🇸 +1</option>
            <option value="+44">🇬🇧 +44</option>
            <option value="+91">🇮🇳 +91</option>
            <option value="+61">🇦🇺 +61</option>
            <option value="+81">🇯🇵 +81</option>
            <option value="+86">🇨🇳 +86</option>
            <option value="+33">🇫🇷 +33</option>
            <option value="+49">🇩🇪 +49</option>
            <option value="+39">🇮🇹 +39</option>
            <option value="+34">🇪🇸 +34</option>
            <option value="+7">🇷🇺 +7</option>
            <option value="+55">🇧🇷 +55</option>
            <option value="+52">🇲🇽 +52</option>
            <option value="+27">🇿🇦 +27</option>
            <option value="+82">🇰🇷 +82</option>
            <option value="+31">🇳🇱 +31</option>
            <option value="+46">🇸🇪 +46</option>
            <option value="+47">🇳🇴 +47</option>
            <option value="+45">🇩🇰 +45</option>
            <option value="+358">🇫🇮 +358</option>
          </select>
          <input
            type="tel"
            id="contact-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-contact-form__input-{{ ai_gen_id }} ai-contact-form__phone-input-{{ ai_gen_id }}"
            value="{{ form.phone }}"
            autocomplete="tel"
          >
        </div>
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-contact-form__label-{{ ai_gen_id }}" for="contact-message-{{ ai_gen_id }}">
          {{ block.settings.message_label }}
        </label>
        <textarea
          id="contact-message-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-contact-form__textarea-{{ ai_gen_id }}"
          required
          {% if form.errors.body %}
            aria-invalid="true"
            aria-describedby="contact-message-error-{{ ai_gen_id }}"
          {% endif %}
        >{{ form.body }}</textarea>
        {%- if form.errors.body -%}
          <div id="contact-message-error-{{ ai_gen_id }}" class="ai-contact-form__error-{{ ai_gen_id }}">
            {{ form.errors.body }}
          </div>
        {%- endif -%}
      </div>

      <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_label }}
      </button>

      {%- if form.posted_successfully? -%}
        <div class="ai-contact-form__success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {%- endif -%}
    </div>
  {%- endform -%}
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "first_name_label",
      "label": "First name label",
      "default": "First name"
    },
    {
      "type": "text",
      "id": "last_name_label",
      "label": "Last name label",
      "default": "Last name"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone label",
      "default": "Phone number"
    },
    {
      "type": "text",
      "id": "message_label",
      "label": "Message label",
      "default": "Message"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for contacting us. We'll get back to you soon!"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "form_padding",
      "label": "Form padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Input background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border",
      "default": "#D1D1D1"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#334FB4"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "success_color",
      "label": "Success message",
      "default": "#008060"
    },
    {
      "type": "color",
      "id": "error_color",
      "label": "Error message",
      "default": "#D82C0D"
    },
    {
      "type": "header",
      "content": "Input style"
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "label": "Input border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Contact form"
    }
  ]
}
{% endschema %}