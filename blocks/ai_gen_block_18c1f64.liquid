{% doc %}
  @prompt
    Create a block that explains these steps in an original way 
    
    How to Use It
    
    Step 1 – Open the Tool: Click Create a Mood Board to launch Style Sourcebook in a pop-up workspace.
    Step 2 – Add Products: Browse Cook & Bathe collections and drag pieces onto the board.
    Step 3 – Refine Your Look: Mix colours, textures and finishes until you’re happy.
    Step 4 – Save or Share: Download your board or share it with your designer.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-steps-guide-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-steps-guide__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-steps-guide__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-steps-guide__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-steps-guide__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-steps-guide__steps-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: {{ block.settings.step_gap }}px;
    margin-top: {{ block.settings.steps_top_margin }}px;
  }

  .ai-steps-guide__step-{{ ai_gen_id }} {
    position: relative;
    padding: {{ block.settings.step_padding }}px;
    background-color: {{ block.settings.step_background }};
    border-radius: {{ block.settings.step_border_radius }}px;
    border: {{ block.settings.step_border_width }}px solid {{ block.settings.step_border_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-steps-guide__step-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-steps-guide__step-number-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.number_size }}px;
    height: {{ block.settings.number_size }}px;
    background-color: {{ block.settings.number_background }};
    color: {{ block.settings.number_color }};
    border-radius: 50%;
    font-size: {{ block.settings.number_font_size }}px;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .ai-steps-guide__step-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_title_size }}px;
    color: {{ block.settings.step_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-steps-guide__step-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_description_size }}px;
    color: {{ block.settings.step_description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-steps-guide__connector-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (min-width: 990px) {
    .ai-steps-guide__steps-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
      position: relative;
    }

    .ai-steps-guide__connector-{{ ai_gen_id }} {
      display: block;
      position: absolute;
      top: {{ block.settings.number_size | divided_by: 2 | plus: block.settings.step_padding }}px;
      left: calc(25% - 20px);
      width: calc(50% + 40px);
      height: 2px;
      background: linear-gradient(
        to right,
        {{ block.settings.connector_color }} 0%,
        {{ block.settings.connector_color }} 45%,
        transparent 45%,
        transparent 55%,
        {{ block.settings.connector_color }} 55%,
        {{ block.settings.connector_color }} 100%
      );
      z-index: 0;
    }

    .ai-steps-guide__step-{{ ai_gen_id }} {
      position: relative;
      z-index: 1;
    }
  }

  @media screen and (max-width: 989px) {
    .ai-steps-guide__steps-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-steps-guide__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-steps-guide__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-steps-guide-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-steps-guide__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-steps-guide__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-steps-guide__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-steps-guide__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-steps-guide__steps-{{ ai_gen_id }}">
      <div class="ai-steps-guide__connector-{{ ai_gen_id }}"></div>

      {% if block.settings.step_1_title != blank %}
        <div class="ai-steps-guide__step-{{ ai_gen_id }}">
          <div class="ai-steps-guide__step-number-{{ ai_gen_id }}">1</div>
          <h3 class="ai-steps-guide__step-title-{{ ai_gen_id }}">{{ block.settings.step_1_title }}</h3>
          {% if block.settings.step_1_description != blank %}
            <p class="ai-steps-guide__step-description-{{ ai_gen_id }}">{{ block.settings.step_1_description }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.step_2_title != blank %}
        <div class="ai-steps-guide__step-{{ ai_gen_id }}">
          <div class="ai-steps-guide__step-number-{{ ai_gen_id }}">2</div>
          <h3 class="ai-steps-guide__step-title-{{ ai_gen_id }}">{{ block.settings.step_2_title }}</h3>
          {% if block.settings.step_2_description != blank %}
            <p class="ai-steps-guide__step-description-{{ ai_gen_id }}">{{ block.settings.step_2_description }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.step_3_title != blank %}
        <div class="ai-steps-guide__step-{{ ai_gen_id }}">
          <div class="ai-steps-guide__step-number-{{ ai_gen_id }}">3</div>
          <h3 class="ai-steps-guide__step-title-{{ ai_gen_id }}">{{ block.settings.step_3_title }}</h3>
          {% if block.settings.step_3_description != blank %}
            <p class="ai-steps-guide__step-description-{{ ai_gen_id }}">{{ block.settings.step_3_description }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.step_4_title != blank %}
        <div class="ai-steps-guide__step-{{ ai_gen_id }}">
          <div class="ai-steps-guide__step-number-{{ ai_gen_id }}">4</div>
          <h3 class="ai-steps-guide__step-title-{{ ai_gen_id }}">{{ block.settings.step_4_title }}</h3>
          {% if block.settings.step_4_description != blank %}
            <p class="ai-steps-guide__step-description-{{ ai_gen_id }}">{{ block.settings.step_4_description }}</p>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

