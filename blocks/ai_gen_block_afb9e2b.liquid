<script>
(function() {
  class ContactForm{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.validationMessages = {};
      this.handleOutsideClick = this.handleOutsideClick.bind(this);
    }

    connectedCallback() {
      this.form = this.querySelector('form');

      this.phoneInput = this.querySelector('[data-field="phone"]');
      this.phoneContainer = this.querySelector('[data-phone-container]');
      this.hiddenPhoneInput = this.querySelector('[data-phone-hidden]');

      this.dropdown = this.querySelector('[data-country-dropdown]');
      this.trigger = this.querySelector('[data-country-trigger]');

      this.selectedCode = this.trigger.querySelector('[data-code]').textContent || '+1';

      this.loadValidationMessages();
      this.setupPhoneField();
      this.setupValidation();

        this.dropdownButton = this.querySelector('.ai-contact-form__dropdown-button-{{ ai_gen_id }}');
        this.dropdownMenu = this.querySelector('.ai-contact-form__dropdown-menu-{{ ai_gen_id }}');
        this.searchInput = this.querySelector('.ai-contact-form__search-input-{{ ai_gen_id }}');
        this.options = this.querySelectorAll('.ai-contact-form__dropdown-option-{{ ai_gen_id }}');
        this.selectedFlag = this.querySelector('.ai-contact-form__selected-flag-{{ ai_gen_id }}');
        this.selectedCode = this.querySelector('.ai-contact-form__selected-code-{{ ai_gen_id }}');
        this.hiddenInput = this.querySelector('.ai-contact-form__country-code-input-{{ ai_gen_id }}');

        this.setupEventListeners();
      
      document.addEventListener('click', this.handleOutsideClick);
    }

    disconnectedCallback() {
      document.removeEventListener('click', this.handleOutsideClick);
    }

    handleOutsideClick(e) {
      if (!this.contains(e.target) && this.dropdown) {
        this.dropdown.classList.remove('active');
      }
    }

    loadValidationMessages() {
      this.validationMessages = {
        email: {
          required: '{{ block.settings.email_required_message }}',
          invalid: '{{ block.settings.email_invalid_message }}'
        },
        firstname: {
          required: '{{ block.settings.firstname_required_message }}'
        },
        lastname: {
          required: '{{ block.settings.lastname_required_message }}'
        },
        phone: {
          required: '{{ block.settings.phone_required_message }}',
          invalid: '{{ block.settings.phone_invalid_message }}'
        },
        message: {
          required: '{{ block.settings.message_required_message }}'
        }
      };
    }

    // =========================
    // PHONE FIELD + FORMATTER
    // =========================
    setupPhoneField() {
      const phoneInput = this.phoneInput;

      const codeEl = this.trigger.querySelector('[data-code]');
      const flagEl = this.trigger.querySelector('[data-flag]');

      // toggle dropdown
      this.trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        this.dropdown.classList.toggle('active');
      });

      // select country code
      this.dropdown.querySelectorAll('.country-option').forEach(opt => {
        opt.addEventListener('click', (e) => {
          e.stopPropagation();

          const code = opt.dataset.code;
          const flag = opt.dataset.flag;

          this.selectedCode = code;

          codeEl.textContent = code;
          flagEl.src = `https://flagcdn.com/w20/${flag}.png`;

          this.dropdown.classList.remove('active');
        });
      });

      // 👉 FORMAT LOCAL NUMBER ONLY
      phoneInput.addEventListener('input', () => {
        let value = phoneInput.value;

        // remove non digits
        let digits = value.replace(/\D/g, '');

        // format: XXX-XXX-XXX
        if (digits.length > 3 && digits.length <= 6) {
          digits = digits.replace(/(\d{3})(\d{1,3})/, '$1-$2');
        } else if (digits.length > 6) {
          digits = digits.replace(/(\d{3})(\d{3})(\d{1,3})/, '$1-$2-$3');
        }

        phoneInput.value = digits;
      });

      phoneInput.addEventListener('focus', () => {
        this.dropdown.classList.remove('active');
      });
    }

    // =========================
    // BUILD FULL PHONE
    // =========================
    getFullPhone() {
      const local = this.phoneInput.value.replace(/\D/g, '');
      if (!local) return '';
      return `${this.selectedCode}${local}`;
    }

    isValidPhone(number) {
      const digits = number.replace(/\D/g, '');
      return digits.length >= 7 && digits.length <= 15;
    }

    isValidEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    setupValidation() {
      this.form.addEventListener('submit', (e) => {
        let isValid = true;
        this.clearErrors();

        const emailInput = this.querySelector('[data-field="email"]');
        const firstnameInput = this.querySelector('[data-field="firstname"]');
        const lastnameInput = this.querySelector('[data-field="lastname"]');
        const phoneInput = this.querySelector('[data-field="phone"]');
        const messageInput = this.querySelector('[data-field="message"]');

        // EMAIL
        if (!emailInput.value.trim()) {
          this.showError('email', this.validationMessages.email.required);
          isValid = false;
        } else if (!this.isValidEmail(emailInput.value)) {
          this.showError('email', this.validationMessages.email.invalid);
          isValid = false;
        }

        // FIRSTNAME
        if (!firstnameInput.value.trim()) {
          this.showError('firstname', this.validationMessages.firstname.required);
          isValid = false;
        }

        // LASTNAME
        if (!lastnameInput.value.trim()) {
          this.showError('lastname', this.validationMessages.lastname.required);
          isValid = false;
        }

        // PHONE
        if (!phoneInput.value.trim()) {
          this.showError('phone', this.validationMessages.phone.required);
          isValid = false;
        } else if (!this.isValidPhone(phoneInput.value)) {
          this.showError('phone', this.validationMessages.phone.invalid);
          isValid = false;
        }

        // MESSAGE
        if (!messageInput.value.trim()) {
          this.showError('message', this.validationMessages.message.required);
          isValid = false;
        }
setupEventListeners() {
        this.dropdownButton.addEventListener('click', (e) => {
          e.preventDefault();
          this.toggleDropdown();
        });

        this.options.forEach(option => {
          option.addEventListener('click', () => {
            this.selectOption(option);
          });
        });

        this.searchInput.addEventListener('input', (e) => {
          this.filterOptions(e.target.value);
        });

        document.addEventListener('click', (e) => {
          if (!this.contains(e.target)) {
            this.closeDropdown();
          }
        });

        this.searchInput.addEventListener('click', (e) => {
          e.stopPropagation();
        });
      }

      toggleDropdown() {
        const isActive = this.dropdownMenu.classList.contains('active');
        if (isActive) {
          this.closeDropdown();
        } else {
          this.openDropdown();
        }
      }

      openDropdown() {
        this.dropdownMenu.classList.add('active');
        this.dropdownButton.setAttribute('aria-expanded', 'true');
        this.searchInput.value = '';
        this.filterOptions('');
        setTimeout(() => {
          this.searchInput.focus();
        }, 100);
      }

      closeDropdown() {
        this.dropdownMenu.classList.remove('active');
        this.dropdownButton.setAttribute('aria-expanded', 'false');
      }

      selectOption(option) {
        const code = option.dataset.code;
        const country = option.dataset.country;
        const flagSrc = option.querySelector('.ai-contact-form__flag-{{ ai_gen_id }}').src;

        this.selectedFlag.src = flagSrc;
        this.selectedCode.textContent = code;
        this.hiddenInput.value = code;

        this.closeDropdown();
      }

      filterOptions(searchTerm) {
        const term = searchTerm.toLowerCase();
        this.options.forEach(option => {
          const name = option.dataset.name.toLowerCase();
          const code = option.dataset.code.toLowerCase();
          if (name.includes(term) || code.includes(term)) {
            option.classList.remove('hidden');
          } else {
            option.classList.add('hidden');
          }
        });
      }
        // 👉 FINAL: store full phone
        if (isValid) {
          this.hiddenPhoneInput.value = this.getFullPhone();
        }

        if (!isValid) e.preventDefault();
      });

      const inputs = this.querySelectorAll('[data-field]');
      inputs.forEach(input => {
        input.addEventListener('blur', () => this.validateField(input));
      });
    }

    validateField(input) {
      const fieldName = input.dataset.field;
      const value = input.value.trim();

      this.clearFieldError(fieldName);

      if (!value) {
        this.showError(fieldName, this.validationMessages[fieldName].required);
        return false;
      }

      if (fieldName === 'email' && !this.isValidEmail(value)) {
        this.showError(fieldName, this.validationMessages.email.invalid);
        return false;
      }

      if (fieldName === 'phone' && !this.isValidPhone(value)) {
        this.showError(fieldName, this.validationMessages.phone.invalid);
        return false;
      }

      return true;
    }

    showError(fieldName, message) {
      const errorSpan = this.querySelector(`[data-error="${fieldName}"]`);
      const input = this.querySelector(`[data-field="${fieldName}"]`);

      if (errorSpan) errorSpan.textContent = message;

      if (input) {
        input.classList.add('error');
        input.setAttribute('aria-invalid', 'true');
      }

      if (fieldName === 'phone' && this.phoneContainer) {
        this.phoneContainer.classList.add('error');
      }
    }

    clearFieldError(fieldName) {
      const errorSpan = this.querySelector(`[data-error="${fieldName}"]`);
      const input = this.querySelector(`[data-field="${fieldName}"]`);

      if (errorSpan) errorSpan.textContent = '';

      if (input) {
        input.classList.remove('error');
        input.removeAttribute('aria-invalid');
      }

      if (fieldName === 'phone' && this.phoneContainer) {
        this.phoneContainer.classList.remove('error');
      }
    }

    clearErrors() {
      this.querySelectorAll('[data-error]').forEach(el => el.textContent = '');

      this.querySelectorAll('[data-field]').forEach(el => {
        el.classList.remove('error');
        el.removeAttribute('aria-invalid');
      });

      if (this.phoneContainer) {
        this.phoneContainer.classList.remove('error');
      }
    }
  }

  customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
})();
</script>

