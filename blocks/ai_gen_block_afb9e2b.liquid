                <div class="ai-contact-form__dropdown-option-{{ ai_gen_id }}" data-code="+33" data-country="fr" data-name="France">
                  <img src="https://flagcdn.com/w20/fr.png" alt="FR" class="ai-contact-form__flag-{{ ai_gen_id }}">
