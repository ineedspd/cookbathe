                <div class="ai-contact-form__dropdown-option-{{ ai_gen_id }}" data-code="+49" data-country="de" data-name="Germany">
                  <img src="https://flagcdn.com/w20/de.png" alt="DE" class="ai-contact-form__flag-{{ ai_gen_id }}">
