                <div class="ai-contact-form__dropdown-option-{{ ai_gen_id }}" data-code="+61" data-country="au" data-name="Australia">
                  <img src="https://flagcdn.com/w20/au.png" alt="AU" class="ai-contact-form__flag-{{ ai_gen_id }}">
