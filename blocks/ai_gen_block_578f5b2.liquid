{% doc %}
  @prompt
    Countdown timer , add fields to the timer to show days, hours, minutes, seconds, the calculations for days is wrong. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-countdown-timer__heading-{{ ai_gen_id }} {
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
  }

  .ai-countdown-timer__display-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.spacing }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer__unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 80px;
  }

  .ai-countdown-timer__value-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.box_size }}px;
    height: {{ block.settings.box_size }}px;
    background-color: {{ block.settings.box_color }};
    color: {{ block.settings.number_color }};
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    border-radius: {{ block.settings.border_radius }}px;
    margin-bottom: 8px;
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 18px;
    display: none;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer__unit-{{ ai_gen_id }} {
      min-width: 60px;
    }

    .ai-countdown-timer__value-{{ ai_gen_id }} {
      width: calc({{ block.settings.box_size }}px * 0.8);
      height: calc({{ block.settings.box_size }}px * 0.8);
      font-size: calc({{ block.settings.number_size }}px * 0.8);
    }

    .ai-countdown-timer__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  data-show-days="{{ block.settings.show_days }}"
  data-show-hours="{{ block.settings.show_hours }}"
  data-show-minutes="{{ block.settings.show_minutes }}"
  data-show-seconds="{{ block.settings.show_seconds }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-countdown-timer__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-countdown-timer__display-{{ ai_gen_id }}">
    {% if block.settings.show_days %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-unit="days">00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Days</div>
      </div>
    {% endif %}
    {% if block.settings.show_hours %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-unit="hours">00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Hours</div>
      </div>
    {% endif %}
    {% if block.settings.show_minutes %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-unit="minutes">00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Minutes</div>
      </div>
    {% endif %}
    {% if block.settings.show_seconds %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-unit="seconds">00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Seconds</div>
      </div>
    {% endif %}
  </div>

  <div class="ai-countdown-timer__expired-{{ ai_gen_id }}">
    {{ block.settings.expired_message }}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.showDays = this.dataset.showDays === 'true';
        this.showHours = this.dataset.showHours === 'true';
        this.showMinutes = this.dataset.showMinutes === 'true';
        this.showSeconds = this.dataset.showSeconds === 'true';
        this.interval = null;
      }

      connectedCallback() {
        if (!this.endDate || !this.endTime) {
          this.showExpired();
          return;
        }

        this.targetDate = new Date(this.endDate + 'T' + this.endTime).getTime();

        if (isNaN(this.targetDate)) {
          this.showExpired();
          return;
        }

        this.updateCountdown();
        this.interval = setInterval(() => this.updateCountdown(), 1000);
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      updateCountdown() {
        const now = new Date().getTime();
        const distance = this.targetDate - now;

        if (distance < 0) {
          this.showExpired();
          if (this.interval) {
            clearInterval(this.interval);
          }
          return;
        }

        let totalSeconds = Math.floor(distance / 1000);
        let totalMinutes = Math.floor(totalSeconds / 60);
        let totalHours = Math.floor(totalMinutes / 60);
        let totalDays = Math.floor(totalHours / 24);

        const days = totalDays;
        const hours = totalHours % 24;
        const minutes = totalMinutes % 60;
        const seconds = totalSeconds % 60;

        if (this.showDays) {
          const daysElement = this.querySelector('[data-unit="days"]');
          if (daysElement) {
            daysElement.textContent = String(days).padStart(2, '0');
          }
        }

        if (this.showHours) {
          const hoursElement = this.querySelector('[data-unit="hours"]');
          if (hoursElement) {
            hoursElement.textContent = String(hours).padStart(2, '0');
          }
        }

        if (this.showMinutes) {
          const minutesElement = this.querySelector('[data-unit="minutes"]');
          if (minutesElement) {
            minutesElement.textContent = String(minutes).padStart(2, '0');
          }
        }

        if (this.showSeconds) {
          const secondsElement = this.querySelector('[data-unit="seconds"]');
          if (secondsElement) {
            secondsElement.textContent = String(seconds).padStart(2, '0');
          }
        }
      }

      showExpired() {
        this.querySelector('.ai-countdown-timer__display-{{ ai_gen_id }}').style.display = 'none';
        this.querySelector('.ai-countdown-timer__expired-{{ ai_gen_id }}').classList.add('active');
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Countdown timer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited Time Offer"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End date",
      "info": "Format: YYYY-MM-DD (e.g., 2025-12-31)",
      "default": "2025-12-31"
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "End time",
      "info": "Format: HH:MM:SS (e.g., 23:59:59)",
      "default": "23:59:59"
    },
    {
      "type": "text",
      "id": "expired_message",
      "label": "Expired message",
      "default": "This offer has ended"
    },
    {
      "type": "header",
      "content": "Display options"
    },
    {
      "type": "checkbox",
      "id": "show_days",
      "label": "Show days",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_hours",
      "label": "Show hours",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_minutes",
      "label": "Show minutes",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_seconds",
      "label": "Show seconds",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "box_color",
      "label": "Box color",
      "default": "#334fb4"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "number_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Number size",
      "default": 36
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Label size",
      "default": 12
    },
    {
      "type": "range",
      "id": "box_size",
      "min": 60,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Box size",
      "default": 80
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Spacing between units",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Countdown timer"
    }
  ]
}
{% endschema %}
